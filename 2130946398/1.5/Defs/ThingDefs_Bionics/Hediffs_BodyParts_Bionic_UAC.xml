  <HediffDef ParentName="ImplantHediffBase">
    <defName>UACCombat_Implant</defName>
    <label>basilisk implant</label>
    <labelNoun>a basilisk implant</labelNoun>
    <description>An installed basilisk implant.</description>
    <descriptionHyperlinks><ThingDef>UACCombat_Implant</ThingDef></descriptionHyperlinks>
    <spawnThingOnRemoved>UACCombat_Implant</spawnThingOnRemoved>
