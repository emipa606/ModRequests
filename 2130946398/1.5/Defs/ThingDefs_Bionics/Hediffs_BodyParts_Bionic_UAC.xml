    <label>install representative implant</label>
    <description>Install a representative implant.</description>
    <descriptionHyperlinks><ThingDef>RH_UACAestheticShaper</ThingDef></descriptionHyperlinks>
    <jobString>Installing super seducer.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>RH_UACAestheticShaper</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
