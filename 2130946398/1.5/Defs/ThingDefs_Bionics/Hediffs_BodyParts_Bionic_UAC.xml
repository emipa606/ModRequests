  </HediffDef>

  <ThingDef ParentName="RH_BodyPartUACtechBase">
    <defName>RH_UACAestheticShaper</defName>
    <label>representative implant</label>
    <description>A UAC brand Aesthetic Shaper, a package of hormonal and mechanite influences shapes the muscles and fat on the body, adding non-functional aesthetic tissue where needed to achieve a desired appearance. This implant can be configured to form various body shapes according to the user’s taste - or that of their partner.\n\nThis implant was produced by the UAC for their corporate reperesentatives, allowing their appearances to be used as an asset for improving relations.</description>
    <descriptionHyperlinks><RecipeDef>InstallRH_UACAestheticShaper</RecipeDef></descriptionHyperlinks>
    <thingSetMakerTags><li>RewardStandardLowFreq</li></thingSetMakerTags>
    <costList>
      <Plasteel>15</Plasteel>
      <ComponentSpacer>6</ComponentSpacer>
    </costList>
    <recipeMaker>
      <researchPrerequisite>AdvancedFabrication</researchPrerequisite>
    </recipeMaker>
	<graphicData>
      <texPath>Things/Item/Health/HealthItem</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.80</drawSize>
      <color>(255, 209, 242)</color>
    </graphicData>
  </ThingDef>

  <RecipeDef ParentName="SurgeryInstallImplantBase">
