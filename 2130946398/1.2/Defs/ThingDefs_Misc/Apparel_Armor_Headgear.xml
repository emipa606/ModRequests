<Defs>
  
  
<!-- ================================== Original ====================================-->

  <ThingDef ParentName="RHArmorHelmetMakeableBase_DOOM">
    <defName>RHApparel_DOOM_PhobosSuitHelmet</defName>
    <label>phobos suit helmet</label>
    <description>The helmet designed by the UAC to be worn with the Phobos Suit. Comes with a heads-up display that enhances the user's situational awareness and accuracy.
	
This helmet fully protects the wearer from toxic fallouts. Due to technological limitations, the UAC has failed to replicate the psychic shielding that the Praetor Suit has.</description>
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <researchPrerequisite>PoweredArmor</researchPrerequisite>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
      <!--<recipeUsers Inherit="False">
        <li>FabricationBench</li>
      </recipeUsers>-->
    </recipeMaker>
    <graphicData>
      <texPath>Things/Apparel/Display/Helmet/PhobosHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <generateCommonality>0.1</generateCommonality>
    <statBases>
      <WorkToMake>25000</WorkToMake>
      <MaxHitPoints>300</MaxHitPoints>
      <Mass>2.0</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.3</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.6</ArmorRating_Blunt>
      <ArmorRating_Heat>1.0</ArmorRating_Heat>
      <Insulation_Cold>20</Insulation_Cold>
      <Insulation_Heat>20</Insulation_Heat>
      <EquipDelay>4</EquipDelay>
    </statBases>
	
		<equippedStatOffsets>
		    <ShootingAccuracyPawn>0.25</ShootingAccuracyPawn>
			<ToxicSensitivity>-1.0</ToxicSensitivity>
			<MentalBreakThreshold>-0.01</MentalBreakThreshold>
			<GlobalLearningFactor>0.10</GlobalLearningFactor>
		</equippedStatOffsets>
		
	<thingCategories>
      <li>RHHeadgear_PoweredArmorHelmets</li>
    </thingCategories>

	
    <costList>
      <ComponentSpacer>4</ComponentSpacer>
      <Plasteel>40</Plasteel>
    </costList>
		<apparel>
		<careIfWornByCorpse>false</careIfWornByCorpse>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Apparel/Helmet/PhobosHelmet</wornGraphicPath>
			<layers>
				<li>Overhead</li>
			</layers>
	  <tags>
        <li>RH_UAC_Phobos</li>
		<li>PassiveCamo_Orange_Set</li>
		<li>PrestigeCombatGear</li>
        <li>EVA</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
    </apparel>
    <thingSetMakerTags>
      <li>RewardSpecial</li>
    </thingSetMakerTags>
  </ThingDef>
  
  <!--=========  UAC Helmets  ===========-->
  
    <ThingDef Name="RH_UACPowerArmorHelmetBase" ParentName="RHArmorHelmetMakeableBase_DOOM" Abstract="True">
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <researchPrerequisite>PoweredArmor</researchPrerequisite>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <!--<recipeUsers Inherit="False">
        <li>FabricationBench</li>
      </recipeUsers>-->
    </recipeMaker>
    <tradeTags>
      <li>HiTechArmor</li>
    </tradeTags>
    <generateCommonality>2</generateCommonality>
    <statBases>
      <WorkToMake>21000</WorkToMake>
      <MaxHitPoints>250</MaxHitPoints>
      <Mass>1.25</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.1</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
      <ArmorRating_Heat>0.55</ArmorRating_Heat>
      <Insulation_Cold>4</Insulation_Cold>
      <Insulation_Heat>2</Insulation_Heat>
      <EquipDelay>4</EquipDelay>
    </statBases>
	
	<equippedStatOffsets>
		 <ShootingAccuracyPawn>0.10</ShootingAccuracyPawn>
		<ToxicSensitivity>-1.0</ToxicSensitivity>
		<MentalBreakThreshold>-0.01</MentalBreakThreshold>
		<GlobalLearningFactor>0.10</GlobalLearningFactor>
	</equippedStatOffsets>
	
	<thingCategories>
      <li>RHHeadgear_PoweredArmorHelmets</li>
    </thingCategories>
	
    <costList>
      <ComponentSpacer>2</ComponentSpacer>
      <Plasteel>40</Plasteel>
    </costList>
    <apparel>
	<careIfWornByCorpse>false</careIfWornByCorpse>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <layers>
        <li>Overhead</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
	  <tags>
        <li>EVA</li>
      </tags>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(255, 255, 255)</only>
        </li>
      </options>
    </colorGenerator>
    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>
    <comps>
      <li Class="CompProperties_BiocodableApparel"/>
    </comps>
  </ThingDef>
  
