    </graphicData>
    <uiIconScale>1.25</uiIconScale>
	
	<apparel>
	<wornGraphicPath>Things/Apparel/Helmet/UAC_Security</wornGraphicPath>
	
      <tags>
        <li>RHApparel_UAC_Security</li>
		<li>PassiveCamo_Colour_Set</li>
		<li>PrestigeCombatGear</li>
      </tags>
	  
	  <!--<useWornGraphicMask>true</useWornGraphicMask>-->
	  
	</apparel>
  </ThingDef>  
  
