<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	                           	<!-- ====================================== business suit =========================================== -->
			
	 <ThingDef ParentName="RHApparelMakeableBase_DOOM">
    <defName>RNApparel_BuisnessSuit_UAC</defName>
    <description>A custom tailor business suit for UAC executives and representatives. It is taken from Glitterworld technology, bullet resistant and keeps the temperature within warm despite its lightweight feel, as if the user is using a parka.\n\nEven though the color scheme of this suit seems to be for evil organizations, it's so sleek and smart in appearance that its wearer can just about persuade you to surrender and let them use you for human experiments.</description>
    <label>business suit UAC</label>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Apparel/Display/UAC_BuisnessSuit</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <costStuffCount>95</costStuffCount>
	<costList>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <thingCategories>
      <li>RHApparel_Formal</li>
    </thingCategories>
    <statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToMake>15000</WorkToMake>
      <Mass>0.35</Mass>
      <Flammability>0.6</Flammability>
      <ArmorRating_Sharp>1.00</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Heat>0.25</ArmorRating_Heat>
      <StuffEffectMultiplierInsulation_Cold>2.00</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.95</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>2.5</EquipDelay>
    </statBases>
	
	<equippedStatOffsets>
      <ArrestSuccessChance>0.25</ArrestSuccessChance>
	  <SocialImpact>0.25</SocialImpact>
	  <TradePriceImprovement>0.25</TradePriceImprovement>
	  <NegotiationAbility>0.25</NegotiationAbility>
	  <TameAnimalChance>0.25</TameAnimalChance>
	  <TrainAnimalChance>0.25</TrainAnimalChance>
    </equippedStatOffsets>
	
		<apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
		<li>Shoulders</li>
        <li>Arms</li>
		<li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Apparel/Shell/UAC_BuisnessSuit</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
      <tags>
        <!--<li>IndustrialBasic</li>-->
		<li>RH_Shell_UACSuit</li>
		<li>PassiveCamo_Dark_Set</li>
		<li>RoyalTier7</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
        <li>Soldier</li>
      </defaultOutfitTags>
	  <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
	<colorGenerator Class="ColorGenerator_StandardApparel" />
  </ThingDef>
  
</Defs>
