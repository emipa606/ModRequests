  <ThingDef Name="RH_UACPowerArmorBase" ParentName="RHArmorMachineableBase_DOOM" Abstract="True">
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <researchPrerequisite>PoweredArmor</researchPrerequisite>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <!--<recipeUsers Inherit="False">
        <li>FabricationBench</li>
      </recipeUsers>-->
    </recipeMaker>
    <generateCommonality>2</generateCommonality>
    <statBases>
      <WorkToMake>50000</WorkToMake>
      <MaxHitPoints>380</MaxHitPoints>
      <Mass>14</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.51</ArmorRating_Blunt>
      <ArmorRating_Heat>0.60</ArmorRating_Heat>
      <Insulation_Cold>40</Insulation_Cold>
      <Insulation_Heat>20</Insulation_Heat>
      <EquipDelay>15</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>1.25</MoveSpeed>
	  <AimingDelayFactor>-0.15</AimingDelayFactor>
	  <MeleeDodgeChance>0.5</MeleeDodgeChance>
    </equippedStatOffsets>
	
	<thingCategories>
      <li>RHApparel_PoweredArmor</li>
    </thingCategories>
	
    <costList>
      <ComponentSpacer>5</ComponentSpacer>
      <Plasteel>100</Plasteel>
	  <Uranium>10</Uranium>
    </costList>
    <apparel>
	<careIfWornByCorpse>false</careIfWornByCorpse>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
	  <!--<useWornGraphicMask>true</useWornGraphicMask>-->
	  <tags>
        <li>EVA</li>
      </tags>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(255, 255, 255)</only>
        </li>
      </options>
    </colorGenerator>
    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>
    <!--<comps>
      <li Class="CompProperties_BiocodableApparel"/>
    </comps>-->
  </ThingDef>
  
