<?xml version="1.0" encoding="utf-8" ?>
<Defs>


    <!-- Toxic Pikeman - slow sniper weak at close range, uses toxic needle gun -->
  
  <ThingDef ParentName="BaseMechanoidWalker">
    <defName>Mech_Toxic_Pikeman</defName>
    <label>Tox pikeman</label>
    <description>A clunky multi-legged combat mechanoid specialized as a long-range weapons platform. Seemingly identical to the original pikeman, this version has slightly lower range but uses a toxic needle gun instead, making it dangerous against organic targets.</description>
    <statBases>
      <MoveSpeed>2.2</MoveSpeed>
      <BandwidthCost MayRequire="Ludeon.Rimworld.Biotech">2</BandwidthCost>
    </statBases>
    <tools>
      <li>
        <label>front left leg</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12.0</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftLeg</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
      <li>
        <label>front right leg</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12.0</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>FrontRightLeg</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>8.5</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>Pikeman</body>
      <baseHealthScale>0.85</baseHealthScale>
      <soundMeleeHitPawn>Pawn_Melee_Punch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_Punch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_Punch_Miss</soundMeleeMiss>
      <lifeStageAges Inherit="False">
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Pikeman_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Pikeman_Death</soundDeath>
          <soundCall>Pawn_Mech_Pikeman_Call</soundCall>
        </li>
        <li MayRequire="Ludeon.Rimworld.Biotech">
          <def>MechanoidFullyFormed</def>
          <minAge>100</minAge>
          <soundWounded>Pawn_Mech_Pikeman_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Pikeman_Death</soundDeath>
          <soundCall>Pawn_Mech_Pikeman_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="BaseMechanoidKind">
    <defName>Mech_Toxic_Pikeman</defName>
    <label>Tox pikeman</label>
    <labelPlural>Toxic Pikemen</labelPlural>
    <race>Mech_Toxic_Pikeman</race>
    <combatPower>115</combatPower>
    <lifeStages>
      <li MayRequire="Ludeon.Rimworld.Biotech"> 
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/PikemanClean</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Pikeman</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>2.4</drawSize>
          <shadowData>
            <volume>(0.4, 0.8, 0.4)</volume>
          </shadowData>
        </bodyGraphicData>
      </li>
      <li> 
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Pikeman</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Pikeman</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>2.4</drawSize>
          <shadowData>
            <volume>(0.4, 0.8, 0.4)</volume>
          </shadowData>
        </bodyGraphicData>
      </li>
    </lifeStages>
    <weaponMoney>9999~9999</weaponMoney>
    <weaponTags>
      <li>MechanoidGunToxicNeedle</li>
    </weaponTags>
    <techHediffsChance>1</techHediffsChance>
    <techHediffsMoney>9999~9999</techHediffsMoney>
  </PawnKindDef>

  

</Defs>