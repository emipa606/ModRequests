<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- lifestage to make it rideable -->
  <LifeStageDef>
    <defName>ToxCentipedeMechanoidFullyFormed</defName>
    <label>fully-formed</label>
    <caravanRideable>true</caravanRideable>
    <visible>false</visible>
  </LifeStageDef>

  <!-- ToxCentipede mech -->
  <ThingDef ParentName="MechCentipede">
    <defName>Mech_ToxCentipede</defName>
    <label>ToxCentipede</label>
    <description>A different variant of the Centipede burner, The Tox centipede has almost the same exact weapon with a small change in ammo type, this centipede fires shells that burst with Tox gas instead.</description>
    <statBases>
      <MoveSpeed>2.8</MoveSpeed>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.80</ArmorRating_Sharp>
      <BandwidthCost>5</BandwidthCost>
      <CaravanRidingSpeedFactor>1.4</CaravanRidingSpeedFactor>
	  <EnergyShieldRechargeRate>0.4</EnergyShieldRechargeRate>
      <EnergyShieldEnergyMax>1.5</EnergyShieldEnergyMax>
    </statBases>
	<comps>
      <li Class="CompProperties_ProjectileInterceptor">
        <radius>1.45</radius>
        <interceptGroundProjectiles>true</interceptGroundProjectiles>
        <color>(0.4, 1.0, 0.4)</color>
        <reactivateEffect>BulletShieldGenerator_Reactivate</reactivateEffect>
        <activeSound>BulletShield_Ambience</activeSound>
        <hitPoints>175</hitPoints>
        <hitPointsRestoreInstantlyAfterCharge>true</hitPointsRestoreInstantlyAfterCharge>
        <chargeDurationTicks>1200</chargeDurationTicks><!-- 20s -->
        <drawWithNoSelection>True</drawWithNoSelection>
        <disarmedByEmpForTicks>3600</disarmedByEmpForTicks>
        <gizmoTipKey>ProjectileInterceptorTip</gizmoTipKey>
      </li>
    </comps>
    <race>
      <body>Mech_ToxCentipede</body>
      <baseBodySize>3.6</baseBodySize>
      <baseHealthScale>3.00</baseHealthScale>
      <lifeStageAges>
        <li>
          <def>ToxCentipedeMechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Centipede_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Centipede_Death</soundDeath>
          <soundCall>Pawn_Mech_Centipede_Call</soundCall>
        </li>
        <li>
          <def>ToxCentipedeMechanoidFullyFormed</def>
          <minAge>100</minAge>
          <soundWounded>Pawn_Mech_Centipede_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Centipede_Death</soundDeath>
          <soundCall>Pawn_Mech_Centipede_Call</soundCall>
        </li>
      </lifeStageAges>
      <bulletStaggerIgnoreBodySize>true</bulletStaggerIgnoreBodySize>
      <mechEnabledWorkTypes>
      </mechEnabledWorkTypes>
    </race>
    <tools>
      <li>
        <label>Mechanical Head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>20</power>
        <cooldownTime>3.0</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
      </li>
    </tools>
  </ThingDef>
  
  <PawnKindDef ParentName="MechCentipedeBase">
    <defName>Mech_ToxCentipede</defName>
    <label>ToxCentipede</label>
    <race>Mech_ToxCentipede</race>
    <allowInMechClusters>true</allowInMechClusters>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/ToxCentipede</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/ToxCentipede</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>3</drawSize>
          <shadowData>
            <volume>(0.6, 0.8, 0.6)</volume>
          </shadowData>
        </bodyGraphicData>
      </li>
       <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/ToxCentipedeAncient</texPath>
		  <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/ToxCentipedeAncient</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>3</drawSize>
          <shadowData>
            <volume>(0.6, 0.8, 0.6)</volume>
          </shadowData>
        </bodyGraphicData>
      </li>
    </lifeStages>
    <weaponMoney>9999~9999</weaponMoney>
    <weaponTags>
      <li>Gun_ToxCannon</li>
	  <li>ToxCannonGun</li>
    </weaponTags>
    <techHediffsChance>1</techHediffsChance>
    <techHediffsMoney>9999~9999</techHediffsMoney>      
    <abilities>
      <li>SmokegasMech</li>
    </abilities>
    <controlGroupPortraitZoom>0.5</controlGroupPortraitZoom>  
  </PawnKindDef>

</Defs>