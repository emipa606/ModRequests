<?xml version="1.0" encoding="utf-8" ?>
<Defs>


  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_ToxSpray</defName>
    <label>Toxic Spray</label>
    <graphicData>
      <texPath>Things/Projectile/ToxShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <color>(100,255,0)</color>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
	<speed>22</speed>
      <damageDef>ToxGas</damageDef>
      <explosionRadius>1.5</explosionRadius>
	  <explosionDelay>100</explosionDelay>
      <explosionRadiusDisplayPadding>3</explosionRadiusDisplayPadding>
      <postExplosionGasType>ToxGas</postExplosionGasType>
      <ai_IsIncendiary>true</ai_IsIncendiary>
      <arcHeightFactor>0.2</arcHeightFactor>
      <shadowSize>0.6</shadowSize>
      <screenShakeFactor>0.5</screenShakeFactor>
    </projectile>
  </ThingDef>

  <ThingDef Abstract="True" ParentName="BaseGun" Name="Gun_ToxSprayBase">
    <label>Tox Grenade launcher</label>
    <description>An Toxic spray, used by special mechanoids to spray an area with tox gas, extremely effective indoors.</description>
    <graphicData>
      <texPath>Things/Weapons/MiniToxBlaster</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>1400</MarketValue>
      <Mass>18</Mass>
      <RangedWeapon_Cooldown>10</RangedWeapon_Cooldown>
    </statBases>
    <techLevel>Spacer</techLevel>
    <generateCommonality>0.5</generateCommonality>
    <tradeability>None</tradeability>
    <weaponClasses>
      <li>RangedLight</li>
    </weaponClasses>
    <tools>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2.6</cooldownTime>
      </li>
    </tools>
    <relicChance>0</relicChance>
  </ThingDef>

  <ThingDef ParentName="Gun_ToxSprayBase">
    <defName>Gun_ToxSpray</defName>
    <destroyOnDrop>true</destroyOnDrop>
    <weaponTags>
      <li>MiniToxSpray</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_ToxSpray</defaultProjectile>
        <forcedMissRadius>1</forcedMissRadius>
        <ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
        <warmupTime>4.0</warmupTime>
        <range>14</range>
        <burstShotCount>2</burstShotCount>
        <soundCast>ThrowGrenade</soundCast>
		 <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>14</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>
	
    

</Defs>