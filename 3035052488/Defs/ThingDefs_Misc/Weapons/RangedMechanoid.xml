<?xml version="1.0" encoding="utf-8" ?>
<Defs>



  <!-- Tox cannon -->

  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_ToxCannon</defName>
    <label>Toxic cannon shell</label>
    <graphicData>
      <texPath>Things/Projectile/StinkyShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <color>(100,255,0)</color>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
	<speed>60</speed>
      <damageDef>ToxGas</damageDef>
      <explosionRadius>2.3</explosionRadius>
      <explosionRadiusDisplayPadding>3</explosionRadiusDisplayPadding>
      <postExplosionGasType>ToxGas</postExplosionGasType>
      <ai_IsIncendiary>true</ai_IsIncendiary>
      <arcHeightFactor>0.2</arcHeightFactor>
      <shadowSize>0.6</shadowSize>
      <screenShakeFactor>0.5</screenShakeFactor>
    </projectile>
  </ThingDef>

  <ThingDef Abstract="True" ParentName="BaseGun" Name="Gun_ToxCannonBase">
    <label>Tox cannon</label>
    <description>An Tox cannon, shoots a shell that will burst into a medium-sized zone of toxic gas, the gas is ineffective against other mechanoids and total anti-toxic entities.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/InfernoCannon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>1400</MarketValue>
      <Mass>18</Mass>
      <RangedWeapon_Cooldown>10</RangedWeapon_Cooldown>
    </statBases>
    <techLevel>Spacer</techLevel>
    <generateCommonality>0.5</generateCommonality>
    <tradeability>None</tradeability>
    <weaponClasses>
      <li>RangedHeavy</li>
    </weaponClasses>
    <tools>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2.6</cooldownTime>
      </li>
    </tools>
    <relicChance>0</relicChance>
  </ThingDef>

  <ThingDef ParentName="Gun_ToxCannonBase">
    <defName>Gun_ToxCannon</defName>
    <destroyOnDrop>true</destroyOnDrop>
    <weaponTags>
      <li>MechanoidGunHeavy</li>
      <li>ToxCannonGun</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_ToxCannon</defaultProjectile>
        <forcedMissRadius>3.5</forcedMissRadius>
        <ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
        <warmupTime>1.0</warmupTime>
        <range>40.0</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>Shot_IncendiaryLauncher</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>14</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>
  
 

</Defs>