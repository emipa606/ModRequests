<?xml version="1.0" encoding="utf-8" ?>
<Patch>

<!-- Heavy Mech Gestation Recipe Patches -->

<Operation Class="PatchOperationAdd">
    <xpath>/Defs</xpath>
  <value>
  <RecipeDef ParentName="HeavyMechanoidRecipe">
    <defName>Mech_ToxCentipede</defName>
    <label>gestate Tox Centipede</label>
    <description>Gestate a Tox Centipede mechanoid.</description>
    <gestationCycles>7</gestationCycles>
    <researchPrerequisite>HighMechtech</researchPrerequisite>
    <ingredients Inherit="False">
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>400</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>170</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>SubcoreHigh</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <Mech_ToxCentipede>1</Mech_ToxCentipede>
    </products>
    <descriptionHyperlinks>
      <ThingDef>Mech_ToxCentipede</ThingDef>
    </descriptionHyperlinks>
  </RecipeDef>
	  </value>
</Operation>

<Operation Class="PatchOperationAdd">
  <xpath>Defs/ThingDef[defName="LargeMechGestator"]/recipes</xpath>
  <order>Prepend</order>
  <value>
      <li>Mech_ToxCentipede</li>
  </value>
</Operation>

<!-- Heavy Mech Ressurection Recipe Patches -->

	<Operation Class="PatchOperationInsert">
		<xpath>Defs/RecipeDef[defName="ResurrectHeavyMech"]/fixedIngredientFilter/thingDefs/li</xpath>
		<value>
			<li>Corpse_Mech_ToxCentipede</li>
		</value>
	</Operation>
	
  <Operation Class="PatchOperationInsert">
	<xpath>Defs/RecipeDef[defName="ResurrectMediumMech"]/fixedIngredientFilter/thingDefs/li</xpath>
