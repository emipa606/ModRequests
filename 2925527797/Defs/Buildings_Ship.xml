<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- cargo hold -->

	<ThingDef ParentName="BuildingBase">
		<defName>BDSCH_CargoHold</defName>
		<label>ship cargo hold</label>
		<description>A large cargo hold designed to endure space travels. Equipped with stasis field to keep its contents intact for centuries, but it won't be started until the ship launches and reactur fully powers.</description>
		<thingClass>Building</thingClass>
		<graphicData>
			<texPath>Things/Building/Ship/BDSCH_ShipCargoHold</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(8,8)</drawSize>
			<shadowData>
				<volume>(5.94, 1.0, 6.71)</volume>
			</shadowData>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<researchPrerequisites>
			<li>ShipCryptosleep</li>
		</researchPrerequisites>
		<altitudeLayer>Building</altitudeLayer>
		<passability>Impassable</passability>
		<blockWind>true</blockWind>
		<fillPercent>1</fillPercent>
		<blockLight>true</blockLight>
		<canOverlapZones>false</canOverlapZones>
		<statBases>
			<WorkToBuild>65000</WorkToBuild>
			<MaxHitPoints>500</MaxHitPoints>
			<Flammability>0</Flammability>
		</statBases>
		<tickerType>Normal</tickerType>
		<size>(6,7)</size>
		<designationCategory>Ship</designationCategory>
		<building>
			<shipPart>true</shipPart>
			<destroySound>BuildingDestroyed_Metal_Big</destroySound>
		</building>
		<costList>
			<Steel>350</Steel>
			<Plasteel>280</Plasteel>
			<ComponentIndustrial>15</ComponentIndustrial>
			<ComponentSpacer>8</ComponentSpacer>
		</costList>
		<comps>
			<li Class="CompProperties_ShipPart"/>
			<li Class="CompProperties_Transporter">
				<restEffectiveness>0</restEffectiveness>
				<canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
				<massCapacity>12600</massCapacity>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_NotUnderRoof</li>
		</placeWorkers>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<defaultPlacingRot>East</defaultPlacingRot>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
		<modExtensions>
			<li Class="BDsShipCargoHold.DefModExtension_ShipCargoHold">
			</li>
		</modExtensions>
	</ThingDef>
</Defs>
