<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<ItemProcessor.CombinationDef>
		<defName>SugarToRum</defName>
		<building>RealRumBarrel</building>
		<items>
			<li>VCE_RawSugar</li>
		</items>	
		<amount>
			<li>10</li>
		</amount>
		<result>VFEP_Rum</result>	
		<yield>10</yield>
		<useQualityIncreasing>false</useQualityIncreasing>
		<singleTimeIfNotQualityIncreasing>10</singleTimeIfNotQualityIncreasing>
	</ItemProcessor.CombinationDef>
	
	<ItemProcessor.ItemAcceptedDef>
		<defName>SugarRumFirstItem</defName>
		<building>RealRumBarrel</building>
		<slot>1</slot>
		<items>			
			<li>VCE_RawSugar</li>						
		</items>							
	</ItemProcessor.ItemAcceptedDef>

<ThingDef ParentName="BuildingBase">

		<defName>RealRumBarrel</defName>
		<label>rum fermenting barrel</label>
		<description>A large barrel for fermenting rum out of sugarcane.</description>
		<thingClass>ItemProcessor.Building_ItemProcessor</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/RumBarrel</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2,2)</drawSize>
			<shaderType>CutoutComplex</shaderType>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<thingCategories>
			<li>BuildingsProduction</li>
		</thingCategories>
		<costList>
			
			<WoodLog>30</WoodLog>
			<Steel>10</Steel>
		</costList>
		<altitudeLayer>Building</altitudeLayer>
		<rotatable>true</rotatable>
		<neverMultiSelect>true</neverMultiSelect>
		<uiIconScale>0.8</uiIconScale>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<Mass>7</Mass>
			<WorkToBuild>500</WorkToBuild>
			<MaxHitPoints>100</MaxHitPoints>
			<Flammability>1</Flammability>
		</statBases>
		<tickerType>Rare</tickerType>
		<size>(1,1)</size>
		<designationCategory>Production</designationCategory>
		<passability>PassThroughOnly</passability>
		<pathCost>70</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<researchPrerequisites>
			<li>Brewing</li>
		</researchPrerequisites>
		<comps>
			
			<li Class="ItemProcessor.CompProperties_ItemProcessor">
				<buildingOnGraphic>Things/RumBarrel</buildingOnGraphic>
				<numberOfInputs>1</numberOfInputs>
				<acceptsNoneAsInput>false</acceptsNoneAsInput>
				<InsertFirstItemDesc>RealRumStartSugarDesc</InsertFirstItemDesc>
				<ignoresIngredientLists>true</ignoresIngredientLists>
				<showProgressBar>true</showProgressBar>
				<isSemiAutomaticMachine>true</isSemiAutomaticMachine>
				<resetSemiautomaticIcon>UI/Sugar</resetSemiautomaticIcon>
				
				<chooseIngredientsIcon>UI/Sugar</chooseIngredientsIcon>

				<bringIngredientsText>RealRumInsertSugar</bringIngredientsText>
				<bringIngredientsDesc>RealRumInsertSugarDesc</bringIngredientsDesc>
				<bringIngredientsIcon>UI/Sugar</bringIngredientsIcon >

				<cancelIngredientsText>RealRumCancelSugar</cancelIngredientsText> 
				<cancelIngredientsDesc>RealRumCancelSugarDesc</cancelIngredientsDesc>
				<cancelIngredientsIcon>UI/Sugar</cancelIngredientsIcon> 
				
				<destroyIngredientsAtStartOfProcess>true</destroyIngredientsAtStartOfProcess>
				
			</li>

		</comps>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<minifiedDef>MinifiedThing</minifiedDef>
	</ThingDef>
  
</Defs>