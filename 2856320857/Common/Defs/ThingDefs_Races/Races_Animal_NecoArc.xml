<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="AnimalThingBase">
		<defName>NecoArc</defName>
		<label>Neco-Arc</label>
		<description>Neco-Arc is a member of the Neco Spirit race, originating from the Great Cat's Village.\nWith enough training, Neco-Arc may or may not help your colony with various tasks.</description>
		<thingClass>NecoArcMod.Pawn_NecoArc</thingClass>
		<statBases>
			<MoveSpeed>6.00</MoveSpeed>
			<ComfyTemperatureMin>-40</ComfyTemperatureMin>
			<ComfyTemperatureMax>40</ComfyTemperatureMax>
			<MarketValue>2500</MarketValue>
			<MeatAmount>50</MeatAmount>
		</statBases>
		<tools>
			<li>
				<label>left paw</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>7</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>right paw</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>7</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>teeth</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
		<race>
			<thinkTreeMain>Animal</thinkTreeMain>
			<body>Monkey</body>
			<predator>true</predator>
			<maxPreyBodySize>0.5</maxPreyBodySize>
			<packAnimal>true</packAnimal>
			<herdAnimal>true</herdAnimal>
			<petness>1</petness>
			<baseBodySize>0.8</baseBodySize>
			<baseHungerRate>0.80</baseHungerRate>
			<baseHealthScale>2</baseHealthScale>
			<foodType>CarnivoreAnimal, OvivoreAnimal, Kibble, Liquor</foodType>
			<leatherDef>Leather_Light</leatherDef>
			<gestationPeriodDays>90</gestationPeriodDays>
			<nameOnTameChance>1</nameOnTameChance>
			<trainability>NA_Humanlike</trainability>
			<trainableTags>
				<li>Basic</li>
				<li>Combat</li>
				<li>Help</li>
				<li>HumanWork</li>
			</trainableTags>
			<untrainableTags>
				<li>Work</li>
			</untrainableTags>
			<wildness>0.2</wildness>
			<wildBiomes>
				<!-- they are rather indiscriminate in where to live so they are more or less evenly distributed between biomes; so it is normalized with biome animal density in mind to be 0.05 at 1 density -->
				<BorealForest>0.025</BorealForest><!-- animalDensity 2.8 rel 0.035-->
				<Tundra>0.064</Tundra><!-- animalDensity 1.1 rel 0.035-->
				<ColdBog>0.02</ColdBog><!-- animalDensity 3.3 rel 0.035-->
				<IceSheet>0.5</IceSheet><!-- animalDensity 0.2 rel 0.05-->
				<SeaIce>1.0</SeaIce><!-- animalDensity 0.1 rel 0.05-->
				<TemperateForest>0.018</TemperateForest><!-- animalDensity 3.7 rel 0.035-->
				<TemperateSwamp>0.016</TemperateSwamp><!-- animalDensity 4.3 rel 0.035-->
				<TropicalRainforest>0.018</TropicalRainforest><!-- animalDensity 5.4 rel 0.05-->
				<TropicalSwamp>0.016</TropicalSwamp><!-- animalDensity 6.5 rel 0.05-->
				<AridShrubland>0.084</AridShrubland><!-- animalDensity 1.8 rel 0.075-->
				<Desert>0.176</Desert><!-- animalDensity 0.4 rel 0.035-->
				<ExtremeDesert>1.0</ExtremeDesert> <!-- animalDensity 0.1 rel 0.05-->
			</wildBiomes>
			<nuzzleMtbHours>12</nuzzleMtbHours>
			<manhunterOnDamageChance>0.35</manhunterOnDamageChance>
			<manhunterOnTameFailChance>0.05</manhunterOnTameFailChance>
			<lifeExpectancy>40</lifeExpectancy>
			<useMeatFrom>Cat</useMeatFrom>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.5</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>2</minAge>
					<soundWounded>NecoArc_Injured</soundWounded>
					<soundDeath>NecoArc_Death</soundDeath>
					<soundCall>NecoArc_Call</soundCall>
					<soundAngry>NecoArc_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_Punch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_Punch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_Punch_Miss</soundMeleeMiss>
			<ageGenerationCurve>
				<points>
					<li>(1,0)</li>
					<li>(4,20)</li>
					<li>(10,60)</li>
					<li>(20,20)</li>
					<li>(30,0)</li>
				</points>
			</ageGenerationCurve>
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
			<li>AnimalPet</li>
		</tradeTags>
	</ThingDef>
