<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Bar Cage -->
  <ThingDef ParentName="FurnitureWithQualityBase">
    <defName>SR_Building_BarCage</defName>
    <thingClass>SR.DA.Thing.Building_BondageBed</thingClass>
    <label>Bar Cage</label>
    <description>A human-sized metal bar cage for holding prisoners. It's low on the ground and uncomfortable.</description>
    <drawGUIOverlay>true</drawGUIOverlay>
    <canOverlapZones>false</canOverlapZones>
    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers>
    <passability>PassThroughOnly</passability>
    <defaultPlacingRot>South</defaultPlacingRot>
    <graphicData>
      <texPath>Things/Building/Furniture/Bed/BarCage</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4,4)</drawSize>
      <color>(62,164,249)</color>
      <damageData>
        <rect>(0,0.05,1,1.95)</rect>
      </damageData>
    </graphicData>
    <drawerType>MapMeshAndRealTime</drawerType>
    <comps>
      <!-- <li Class="CompProperties_Forbiddable" /> -->
      <!-- 设施影响 梳妆台 桌子之类  继承bed必须实现的接口，没有使用到-->
      <li Class="CompProperties_AffectedByFacilities">
        <linkableFacilities>
        </linkableFacilities>
      </li>
      <!-- 交互 -->
      <li Class="CompProperties_Usable">
        <compClass>SR.DA.Component.CompUsableBondageBed</compClass>
        <useJob>SR_Job_BondageBed</useJob>
        <useLabel>bound</useLabel>
      </li>
      <!-- 触发效果 -->
      <li Class="CompProperties_UseEffect">
        <compClass>SR.DA.Component.CompEffectBondageBed</compClass>
      </li>
      <!-- 移除效果 -->
      <li Class="CompProperties_UseEffect">
        <compClass>SR.DA.Component.CompRemoveEffectBondageBed</compClass>
      </li>
      <!-- 继承bed必须实现的接口，没有使用到 -->
      <li Class="CompProperties_AssignableToPawn">
        <drawAssignmentOverlay>false</drawAssignmentOverlay>
        <compClass>CompAssignableToPawn</compClass>
      </li>
      <!-- layer扩展 graphic与layer对应 -->
      <li Class="SR.DA.Component.CompProperties_LayerExtension">
        <compClass>SR.DA.Component.CompLayerExtension</compClass>
        <gas>
          <li>
            <graphicData>
              <texPath>Things/Building/Furniture/Bed/BarCageLayerA</texPath>
              <graphicClass>Graphic_Multi</graphicClass>
              <shaderType>CutoutComplex</shaderType>
              <drawSize>(4,4)</drawSize>
            </graphicData>
            <altitudeLayer>Pawn</altitudeLayer>
          </li>
        </gas>
      </li>
    </comps>
    <statBases>
      <MaxHitPoints>140</MaxHitPoints>
      <Flammability>1.0</Flammability>
      <TerrorSource MayRequire="Ludeon.RimWorld.Ideology">40</TerrorSource>
      <Beauty>1</Beauty>
      <WorkToBuild>1200</WorkToBuild>
      <Mass>30</Mass>
      <BedRestEffectiveness>1</BedRestEffectiveness>
      <Comfort>0.09</Comfort>
      <ImmunityGainSpeedFactor>1.07</ImmunityGainSpeedFactor>
      <SurgerySuccessChanceFactor>1</SurgerySuccessChanceFactor>
    </statBases>
    <size>(1,2)</size>
    <!-- 混合材料 -->
    <stuffCategories>
      <li>Metallic</li>
    </stuffCategories>
    <costStuffCount>45</costStuffCount>
    <!-- 额外固定消耗 -->
    <building>
      <bed_showSleeperBody>true</bed_showSleeperBody>
      <bed_healPerDay>4</bed_healPerDay>
    </building>
    <fillPercent>0.4</fillPercent>
    <pathCost>60</pathCost>
    <staticSunShadowHeight>0.17</staticSunShadowHeight>
    <castEdgeShadows>True</castEdgeShadows>
    <designationHotKey>Misc2</designationHotKey>
    <techLevel>Medieval</techLevel>
    <researchPrerequisites>
      <li>SR_RP_BondageBed</li>
    </researchPrerequisites>
    <uiIconScale>0.90</uiIconScale>
  </ThingDef>	
	
