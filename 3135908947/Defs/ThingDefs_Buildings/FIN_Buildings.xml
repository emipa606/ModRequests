<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<ThingDef ParentName="BuildingBase" Name="DecorationVaultBuildingBase" Abstract="true">
		<drawerType>MapMeshAndRealTime</drawerType>
		<fillPercent>0</fillPercent>
		<tickerType>Normal</tickerType>
		<drawGUIOverlay>true</drawGUIOverlay>
		<altitudeLayer>Building</altitudeLayer>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<WorkToBuild>2000</WorkToBuild>
			<Flammability>1</Flammability>
			<Mass>3</Mass>
			<Beauty>5</Beauty>
		</statBases>
		<pathCost>10</pathCost>
		<designationCategory>Furniture</designationCategory>
		<leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
		<resourcesFractionWhenDeconstructed>1</resourcesFractionWhenDeconstructed>
	</ThingDef>
	<ThingDef ParentName="DecorationVaultBuildingBase">
		<defName>DecorationVault_LargeGoldBar</defName>
		<label>Large stack of gold bars</label>
		<description>Incredible wealth and power, a single stack is worth the same as an entire medium-sized colony</description>
		<graphicData>
			<texPath>Things/LargeGoldBar/LargeGoldBar</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<staticSunShadowHeight>0.5</staticSunShadowHeight>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<costList>
			<Gold>5000</Gold>
		</costList>
		<size>1,1</size>
		<minifiedDef>MinifiedThing</minifiedDef>
		<clearBuildingArea>false</clearBuildingArea>
		<statBases>
			<Beauty>1640</Beauty>
		</statBases>
		<building>
			<isEdifice>false</isEdifice>
			<canPlaceOverWall>true</canPlaceOverWall>
			<!-- Large stack will be an edifice NEXT UPDOOT -->
		</building>
		<researchPrerequisites>
			<li>FinanceBanking</li>
		</researchPrerequisites>
	</ThingDef>
	<ThingDef ParentName="DecorationVaultBuildingBase">
		<defName>DecorationVault_SmallGoldBar</defName>
		<label>Small stack of gold bars</label>
		<description>Incredible wealth and power, a single stack is worth the same as an entire small colony</description>
		<graphicData>
			<texPath>Things/SmallGoldBar/SmallGoldBar</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<staticSunShadowHeight>0.5</staticSunShadowHeight>
		<costList>
			<Gold>2000</Gold>
		</costList>
		<size>1,1</size>
		<minifiedDef>MinifiedThing</minifiedDef>
		<clearBuildingArea>false</clearBuildingArea>
		<statBases>
			<Beauty>820</Beauty>
		</statBases>
		<building>
			<isEdifice>false</isEdifice>
			<canPlaceOverWall>true</canPlaceOverWall>
		</building>
		<researchPrerequisites>
			<li>FinanceBanking</li>
		</researchPrerequisites>
	</ThingDef>
	<ThingDef ParentName="DecorationVaultBuildingBase">
		<defName>DecorationVault_CashStacks_Green</defName>
		<label>Cash Stacks - Outlander</label>
		<description>Large array of high denomination bills from the system's major accepted currencies. This specific variation is commonly used by outlanders and other industrial-level societies such as settlers.</description>
		<graphicData>
			<texPath>Things/CashStax/CashStacks_Green</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(1.9,1.9)</drawSize>
		</graphicData>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<staticSunShadowHeight>0.5</staticSunShadowHeight>
		<costList>
			<Silver>5000</Silver>
		</costList>
		<uiIconScale>1</uiIconScale>
		<designatorDropdown>CashStax</designatorDropdown>
		<minifiedDef>MinifiedThing</minifiedDef>
		<clearBuildingArea>false</clearBuildingArea>
		<building>
			<isEdifice>false</isEdifice>
			<canPlaceOverWall>true</canPlaceOverWall>
		</building>
		<statBases>
			<MarketValue>5000</MarketValue>
			<Beauty>410</Beauty>
		</statBases>
		<researchPrerequisites>
			<li>FinanceBanking</li>
		</researchPrerequisites>
	</ThingDef>
