	<ThingDef ParentName="LWM_DeepStorage">
		<defName>DecorationVault_GemBox</defName>
		<label>Gem box</label>
		<description>Crate containing a large stash of gems</description>
		<pathCost>50</pathCost>
		<graphicData>
			<texPath>Things/GemBox/GemBox</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.2,2.2)</drawSize>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<size>1,1</size>
		<staticSunShadowHeight>0.3</staticSunShadowHeight>
		<stuffCategories>
			<li>Metallic</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<Mass>5</Mass>
			<WorkToBuild>2500</WorkToBuild>
			<Flammability>1.0</Flammability>
		</statBases>
		<building>
			<ignoreStoredThingsBeauty>false</ignoreStoredThingsBeauty>
			<fixedStorageSettings>
				<filter>
					<thingDefs>
						<li MayRequire="kikohi.jewelry">Diamond</li>
						<li MayRequire="kikohi.jewelry">Ruby</li>
						<li MayRequire="kikohi.jewelry">Sapphire</li>
					</thingDefs>
				</filter>
			</fixedStorageSettings>
		</building>
		<comps>
			<li Class="LWM.DeepStorage.Properties">
				<maxNumberStacks>25</maxNumberStacks>
				<timeStoringTakes>15</timeStoringTakes>
				<minNumberStacks>5</minNumberStacks>
				<maxTotalMass>2.5</maxTotalMass>
				<showContents>false</showContents>
				<overlayType>SumOfAllItems</overlayType>
			</li>
		</comps>
		<minifiedDef>MinifiedThing</minifiedDef>
		<researchPrerequisites>
			<li>SterileMaterials</li>
		</researchPrerequisites>
	</ThingDef>
	<ThingDef ParentName="LWM_DeepStorage">
		<defName>DecorationVault_JewelryBox</defName>
		<label>Jewelry box</label>
		<description>A box for containing and displaying jewelry. If you have hospitality, make a jewelry store :D</description>
		<pathCost>50</pathCost>
		<graphicData>
			<texPath>Things/JewelryBox/JewelryBox</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.4,2.4)</drawSize>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<size>1,1</size>
		<staticSunShadowHeight>0.3</staticSunShadowHeight>
		<stuffCategories>
			<li>Metallic</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<Mass>5</Mass>
			<WorkToBuild>2500</WorkToBuild>
			<Flammability>0.0</Flammability>
			<Beauty>20</Beauty>
		</statBases>
		<building>
			<fixedStorageSettings>
				<filter>
				  <categories>
					<li MayRequire="kikohi.jewelry">K_Jewelry</li>
				  </categories>
				</filter>
			</fixedStorageSettings>
			<defaultStorageSettings>
				<filter>
				  <categories>
					<li MayRequire="kikohi.jewelry">K_Jewelry</li>
				  </categories>
				</filter>
			</defaultStorageSettings>
		</building>
		<minifiedDef>MinifiedThing</minifiedDef>
		<comps>
			<li Class="LWM.DeepStorage.Properties">
				<maxNumberStacks>20</maxNumberStacks>
				<minNumberStacks>5</minNumberStacks>
				<maxTotalMass>2.5</maxTotalMass>
				<timeStoringTakes>150</timeStoringTakes>
				<overlayType>SumOfAllItems</overlayType>
				<showContents>false</showContents>
			</li>
		</comps>
		<researchPrerequisites>
			<li>SterileMaterials</li>
		</researchPrerequisites>
	</ThingDef>
