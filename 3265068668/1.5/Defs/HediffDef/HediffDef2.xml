<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>WB_Raging</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>raging</label>
    <description>I'll beat up anyone who hurts my Giver!</description>
    <defaultLabelColor>(1,0,0)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <stages>
      <li>
        <label>minor</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <label>serious</label>
        <minSeverity>0.33</minSeverity>
        <becomeVisible>false</becomeVisible>
        <statOffsets>
          <MoveSpeed>3</MoveSpeed>
        </statOffsets>
        <statFactors>
          <MeleeDamageFactor>1.5</MeleeDamageFactor>
          <MeleeCooldownFactor>0.2</MeleeCooldownFactor>
        </statFactors>
        <painFactor>0.333</painFactor>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>2.00</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-16</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>WB_StillHalfAsleepyForMaster</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>still half asleep</label>
    <description>mumble mumble...</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-24</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li>
        <blocksSleeping>true</blocksSleeping>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.9</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.9</postFactor>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>WB_EfficacyOfGiversHerbalTea</defName>
    <label>efficacy of giver's herbal tea</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>The efficacy of giver's herbal tea will temporarily improve your immunity and healing speed, allowing you to sleep more soundly than usual. This effect lasts for 3 days.</description>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <maxSeverity>0.9</maxSeverity>
    <defaultLabelColor>(1.0, 1.0, 1.0)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.3</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>BloodFiltration</capacity><!-- 腎機能 -->
            <postFactor>1.1</postFactor><!-- 1.1倍 -->
          </li>
        </capMods>
        <naturalHealingFactor>1.1</naturalHealingFactor><!-- 自然治癒速度1.1倍 -->
        <statFactors>
          <RestRateMultiplier>1.1</RestRateMultiplier><!-- 睡眠効率1.1倍 -->
        </statFactors>
      </li>
    </stages>
  </HediffDef>

</Defs>
  