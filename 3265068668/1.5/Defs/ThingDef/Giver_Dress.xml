<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>WB_Apparel_MaidOutfit</defName>
    <label>giver’s maid outfit</label>
    <description>A cute maid outfit matching with Giver.</description>
    <possessionCount>1</possessionCount>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
      <displayPriority>215</displayPriority>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Item/Dress/WB_GiverApparel/WB_GiverApparel</texPath>
      <shaderType>CutoutComplex</shaderType>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
    <costStuffCount>80</costStuffCount>
    <stuffCategories>
      <li>Fabric</li>
    </stuffCategories>
    <thingCategories>
      <li>ApparelMisc</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToMake>15000</WorkToMake>
      <Mass>2</Mass>
      <StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.7</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.7</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>4</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <CleaningSpeed>0.1</CleaningSpeed>
      <CookSpeed>0.05</CookSpeed>
      <DrugCookingSpeed>0.05</DrugCookingSpeed>
      <MedicalPotency>0.025</MedicalPotency>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Item/Dress/WB_GiverApparel/WB_GiverApparel</wornGraphicPath>
      <useWornGraphicMask>true</useWornGraphicMask>
      <layers>
        <li>Shell</li>
      </layers>
      <tags Inherit="false">
        <li>WB_Giver</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <drawData>
        <defaultData>
          <layer>48</layer>
        </defaultData>
      </drawData>
      <gender>Female</gender>
    </apparel>
    <tradeTags>
      <li>BasicClothing</li>
    </tradeTags>
    <allowedArchonexusCount>1</allowedArchonexusCount>
  </ThingDef>

  <ThingDef ParentName="HatMakeableBase"  Name="WB_Giver_MaidHeaddress">
    <defName>WB_Apparel_MaidHeaddress</defName>
    <label>giver’s maid headdress</label>
    <description>A cute maid headdress matching with Giver.</description>
    <possessionCount>1</possessionCount>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
      <displayPriority>100</displayPriority>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Item/Dress/WB_GiverZukin/WB_GiverZukin</texPath>
      <shaderType>CutoutComplex</shaderType>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
    <costStuffCount>25</costStuffCount>
    <stuffCategories>
      <li>Fabric</li>
    </stuffCategories>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToMake>2000</WorkToMake>
      <Mass>0.14</Mass>
      <StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.30</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.30</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>1</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <CleaningSpeed>0.1</CleaningSpeed>
      <CookSpeed>0.05</CookSpeed>
      <DrugCookingSpeed>0.05</DrugCookingSpeed>
      <MedicalPotency>0.025</MedicalPotency>
    </equippedStatOffsets>
    <apparel>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <developmentalStageFilter>Adult</developmentalStageFilter>
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Item/Dress/WB_GiverZukin/WB_GiverZukin</wornGraphicPath>
      <useWornGraphicMask>true</useWornGraphicMask>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags Inherit="false">
        <li>WB_Giver</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <drawData>
        <scale>0.76</scale>
      </drawData>
      <gender>Female</gender>
    </apparel>
    <tradeTags>
      <li>BasicClothing</li>
    </tradeTags>
    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_HairTrimmingMask">
        <maskPath>Things/Item/Dress/WB_GiverZukin/WB_GiverZukinHM</maskPath>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="WB_Giver_MaidHeaddress">
    <defName>WB_Apparel_MaidHeaddressWithWig</defName>
    <label>giver’s maid headdress(wigged)</label>
    <description>A cute maid headdress matching with Giver, with a wig included.</description>
    <graphicData>
      <texPath>Things/Item/Dress/WB_GiverZukinWithWig/WB_GiverZukinWithWig</texPath>
      <shaderType>CutoutComplex</shaderType>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
    <apparel>
      <wornGraphicPath>Things/Item/Dress/WB_GiverZukinWithWig/WB_GiverZukinWithWig</wornGraphicPath>
      <drawData>
        <scale>1.0</scale>
        <defaultData>
          <offset>(0.0,0,-0.03)</offset>
        </defaultData>
      </drawData>
    </apparel>
    <modExtensions  Inherit="false">
      <li Class="seekiworks_GiverTheColonyHelper.WB_HairTrimmingMask">
        <maskPath>Things/Item/Dress/WB_GiverZukinWithWig/WB_GiverZukinWithWigHM</maskPath>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>