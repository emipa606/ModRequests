<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="AnimalThingBase">
    <defName>WB_Giver</defName>
    <label>giver</label>
    <description>The Giver was originally an artificial livestock created by genetically modifying a girl and cultivating it through cloning in order to solve the food problem of a contaminated and barren planet. \nPeople were greatly helped by these cloned women, but they were treated extremely poorly by the people, and it was not uncommon for them to meet a horrible end.\nThe genius scientist took pity on the Givers and continued to genetically modify her so that she would be cute, ageless, and hardworking so that people would love her. \nThe Giver thus born succeeded in having many useful functions to support colony operations, but her reproductive ability was lost. \nNowadays, Givers are valuable assets that are very useful for colony management, and are traded at high prices. \nShe is a very gentle and hard worker who will support your colony with her warm fur and special milk and herbal tea.\nShe loves berries and is very happy when given them.</description>
    <statBases>
      <ComfyTemperatureMin>-2000</ComfyTemperatureMin>
      <ComfyTemperatureMax>2000</ComfyTemperatureMax>
      <MeatAmount>80</MeatAmount>
      <LeatherAmount>20</LeatherAmount>
      <ArmorRating_Blunt>0.30</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.1</ArmorRating_Sharp>
      <ArmorRating_Heat>0.75</ArmorRating_Heat>
      <ToxicResistance>1</ToxicResistance>
      <ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
      <PsychicSensitivity>1</PsychicSensitivity>
      <Flammability>0.9</Flammability>
      <MoveSpeed>6.0</MoveSpeed>
      <CarryingCapacity>106</CarryingCapacity><!-- インベントリに入れられる量の上限。運搬とは関係ない。キャラバン積載量とも関係ない。 -->
      <MarketValue>1200</MarketValue>
      <Mass>45</Mass>
      <ImmunityGainSpeed>2</ImmunityGainSpeed>
      <LifespanFactor>20</LifespanFactor>
      <FilthRate>0</FilthRate>
      <Fertility MayRequire="Ludeon.RimWorld.Biotech">0</Fertility>
      <DecompressionResistance MayRequire="kentington.saveourship2">0.749</DecompressionResistance>
      <HypoxiaResistance MayRequire="kentington.saveourship2">0.749</HypoxiaResistance>
    </statBases>
    <tools>
      <li>
        <label>left hand</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <cooldownTime>1.55</cooldownTime>
        <power>5</power>
        <linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
      </li>
      <li>
        <label>right hand</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <cooldownTime>1.55</cooldownTime>
        <power>5</power>
        <linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>20</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
    </tools>
    <race>
      <body>Human</body>
      <thinkTreeMain>WB_Giver</thinkTreeMain><!-- ここでAIの行動ルーチンを指定する。 -->
      <petness>0.1</petness>
      <baseBodySize>0.8</baseBodySize>
      <baseHungerRate>0.2</baseHungerRate>
      <leatherDef>WB_Giver_Wool</leatherDef>
      <baseHealthScale>0.70</baseHealthScale>
      <foodType>Kibble, Meat, Plant, AnimalProduct, VegetableOrFruit, Fungus, Meal, Fluid</foodType>
      <gestationPeriodDays>0</gestationPeriodDays>
      <packAnimal>true</packAnimal>
      <herdAnimal>true</herdAnimal>
      <nameOnTameChance>1</nameOnTameChance>
      <canReleaseToWild>false</canReleaseToWild>
      <trainability>None</trainability>
      <wildness>0</wildness>
      <herdMigrationAllowed>false</herdMigrationAllowed>
      <nuzzleMtbHours>16</nuzzleMtbHours><!-- 擦り寄り頻度 -->
      <hasGenders>false</hasGenders>
      <wildBiomes>
        <SeaIce>0.00025</SeaIce>
        <IceSheet>0.0005</IceSheet>
        <Tundra>0.001</Tundra>
        <ColdBog>0.0015</ColdBog>
        <BorealForest>0.0015</BorealForest>
        <TemperateForest>0.0025</TemperateForest>
        <TemperateSwamp>0.0025</TemperateSwamp>
        <TropicalSwamp>0.0015</TropicalSwamp>
        <TropicalRainforest>0.0015</TropicalRainforest>
        <AridShrubland>0.001</AridShrubland>
        <Desert>0.0005</Desert>
        <ExtremeDesert>0.0005</ExtremeDesert>
      </wildBiomes>
      <lifeExpectancy>999</lifeExpectancy><!-- 寿命 -->
       <lifeStageAges>
        <li>
          <def>AnimalBaby</def><!-- 乳児 -->
          <minAge>0</minAge><!-- 0歳以上 -->
        </li>
        <li>
          <def>WB_AnimalJuvenile</def><!-- 子供だけどミルクは出る -->
          <minAge>3</minAge><!-- 3歳以上 -->
        </li>
        <li>
          <def>AnimalAdult</def><!-- 大人 -->
          <minAge>7</minAge><!-- 7歳以上 -->
        </li>
      </lifeStageAges>
      <ageGenerationCurve>
         <points><!-- 確率は各年齢の間を直線的に変化する。左が年齢、右は重み付け -->
            <li>(4,0)</li><!-- 下限は4歳としているので乳児は出ません -->
            <li>(5,0.1)</li><!-- 5歳以下は重み付け0.1なので急速に出にくくなる -->
            <li>(7,1)</li>
            <li>(18,3)</li><!-- この例では18歳をピークに4超、25歳未満が生成される -->
            <li>(22,1)</li>
            <li>(24,0.2)</li><!-- 24歳以上は重み付け0.2なので急速に出にくくなる -->
            <li>(25,0)</li><!-- 上限は25歳を指定。 -->
         </points>
      </ageGenerationCurve>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <!--<renderTree>WB_Giver</renderTree>-->
    </race>
    <comps>
