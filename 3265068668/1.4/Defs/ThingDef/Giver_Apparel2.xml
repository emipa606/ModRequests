<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="ApparelNoQualityBase" Name="WB_Giver_Accessory" Abstract="True">
    <thingClass>seekiworks_GiverTheColonyHelper.WB_Apparel</thingClass>
    <thingCategories>
      <li>WB_Giveracc</li>
    </thingCategories>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <renderQueue>2901</renderQueue>
    </graphicData>
    <techLevel>Neolithic</techLevel>
    <generateCommonality>0</generateCommonality>
    <generateAllowChance>0</generateAllowChance><!-- 自然湧きポーンは装備しない -->
    <smeltable>false</smeltable>
    <statBases>
      <MaxHitPoints>20</MaxHitPoints>
      <WorkToMake>10</WorkToMake>
      <Mass>0.05</Mass>
      <MarketValue>600</MarketValue>
      <StuffEffectMultiplierArmor>0</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>0.5</EquipDelay>
      <DeteriorationRate>1</DeteriorationRate>
    </statBases>
    <tradeability>Sellable</tradeability>
    <tickerType>Rare</tickerType>
    <apparel>
      <countsAsClothingForNudity>true</countsAsClothingForNudity>
      <bodyPartGroups>
        <li>Neck</li>
      </bodyPartGroups>
      <useWornGraphicMask>true</useWornGraphicMask>
      <layers>
        <li>Overhead</li>
      </layers>
      <developmentalStageFilter>Child, Adult</developmentalStageFilter>
      <tags>
        <li>WB_Giver</li>
      </tags>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <wearPerDay>0</wearPerDay>
      <gender>Female</gender>
    </apparel>
    <allowedArchonexusCount>1</allowedArchonexusCount>
  </ThingDef>


  <ThingDef ParentName="WB_Giver_Accessory">
    <defName>WB_Giveracc_BigRibbonGreen</defName>
    <label>big green ribbon</label>
    <description>big green ribbon</description>
    <thingClass>seekiworks_GiverTheColonyHelper.WB_Apparel</thingClass>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <ArmorRating_Sharp>0.1</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.1</ArmorRating_Blunt>
      <ArmorRating_Heat>0.2</ArmorRating_Heat>
      <Insulation_Cold>5</Insulation_Cold>
    </statBases>
    <graphicData>
      <texPath>Things/Item/Accessory/WB_Giveracc_BigRibbonGreen</texPath>
    </graphicData>
    <apparel>
      <wornGraphicPath>Things/Item/Accessory/WB_Giveracc_BigRibbonGreen</wornGraphicPath>
      <bodyPartGroups Inherit="false">
        <li>UpperHead</li>
      </bodyPartGroups>
    </apparel>
  </ThingDef>

  <ThingDef ParentName="WB_Giver_Accessory">
    <defName>WB_Giveracc_BigRibbonRed</defName>
    <label>big red ribbon</label>
    <description>big red ribbon</description>
    <thingClass>seekiworks_GiverTheColonyHelper.WB_Apparel</thingClass>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <ArmorRating_Sharp>0.1</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.1</ArmorRating_Blunt>
      <ArmorRating_Heat>0.2</ArmorRating_Heat>
      <Insulation_Cold>5</Insulation_Cold>
    </statBases>
    <graphicData>
      <texPath>Things/Item/Accessory/WB_Giveracc_BigRibbonRed</texPath>
    </graphicData>
    <apparel>
      <wornGraphicPath>Things/Item/Accessory/WB_Giveracc_BigRibbonRed</wornGraphicPath>
      <bodyPartGroups Inherit="false">
        <li>UpperHead</li>
      </bodyPartGroups>
    </apparel>
  </ThingDef>

</Defs>