<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationInsert">
    <xpath>*/ThinkTreeDef[defName = "WB_SatisfyBasicNeeds"]/thinkRoot[@Class="ThinkNode_Tagger"]/subNodes/li[@Class="ThinkNode_PrioritySorter"]/subNodes//li[2]</xpath>
    <value>
      <li Class="DubsBadHygiene.JobGiver_HaveWash"/>
    </value>
  </Operation>

  <Operation Class="PatchOperationInsert">
    <xpath>*/ThinkTreeDef[defName = "WB_SatisfyBasicNeeds"]/thinkRoot[@Class="ThinkNode_Tagger"]/subNodes/li[@Class="ThinkNode_PrioritySorter"]/subNodes//li[2]</xpath>
    <value>
      <li Class="DubsBadHygiene.JobGiver_UseToilet"/>
    </value>
  </Operation>

  <Operation Class="PatchOperationInsert">
    <xpath>*/ThinkTreeDef[defName = "WB_SatisfyBasicNeeds"]/thinkRoot[@Class="ThinkNode_Tagger"]/subNodes/li[@Class="ThinkNode_PrioritySorter"]/subNodes//li[2]</xpath>
    <value>
      <li Class="DubsBadHygiene.JobGiver_DrinkWater"/>
    </value>
  </Operation>

  <Operation Class="PatchOperationAddModExtension">
    <xpath>/Defs/ThingDef[defName="WB_Giver_Milk"]</xpath>
    <value>
      <li Class="DubsBadHygiene.WaterExt">
        <water>0.10</water>
        <SeekForThirst>false</SeekForThirst>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAddModExtension">
    <xpath>/Defs/ThingDef[defName="WB_Giver_Herbaltea"]</xpath>
    <value>
      <li Class="DubsBadHygiene.WaterExt">
        <water>1.00</water>
        <SeekForThirst>false</SeekForThirst>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAddModExtension">
    <xpath>/Defs/ThingDef[defName="WB_Giver_Milkherbaltea"]</xpath>
    <value>
      <li Class="DubsBadHygiene.WaterExt">
        <water>0.80</water>
        <SeekForThirst>false</SeekForThirst>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAddModExtension">
    <xpath>/Defs/ThingDef[defName="WB_Giver_Milkshake"]</xpath>
    <value>
      <li Class="DubsBadHygiene.WaterExt">
        <water>0.80</water>
        <SeekForThirst>false</SeekForThirst>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAddModExtension">
    <xpath>/Defs/ThingDef[defName="WB_Giver_Thrumbocookies"]</xpath>
    <value>
      <li Class="DubsBadHygiene.WaterExt">
        <water>0</water>
        <SeekForThirst>false</SeekForThirst>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAttributeAdd">
    <xpath>Defs/ThingDef[defName="Fountain"]</xpath>
    <attribute>Name</attribute>
    <value>DBH_Fountain</value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs</xpath>
    <value>
      <ThingDef ParentName="DBH_Fountain" DBHThirstAddon="true">
        <defName>WB_Fountain</defName>
        <label>fountain for givers</label>
        <description>This water fountain can be used by animals such as the Giver.</description>
        <thingClass>DubsBadHygiene.Building_WaterTrough</thingClass>
        <graphicData>
          <drawSize>(2,2)</drawSize>
          <graphicClass>Graphic_Multi</graphicClass>
          <shaderType>Cutout</shaderType>
          <texPath>DBH/Things/Building/WB_fountain</texPath>
        </graphicData>
        <costList Inherit="false">
          <Steel>15</Steel>
        </costList>
        <stuffCategories Inherit="false">
        </stuffCategories>
        <costStuffCount>0</costStuffCount>
        <rotatable>true</rotatable>
      </ThingDef>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs</xpath>
    <value>
      <ThingDef ParentName="DBH_Fountain" DBHThirstAddon="true">
        <defName>WB_FountainMarble</defName>
        <label>fountain for givers(Long-tailed Tit ver)</label>
        <description>This water fountain can be used by animals such as the Giver.marble long-tailed tit version.</description>
        <thingClass>DubsBadHygiene.Building_WaterTrough</thingClass>
        <graphicData>
          <drawSize>(2,2)</drawSize>
          <graphicClass>Graphic_Multi</graphicClass>
          <shaderType>Cutout</shaderType>
          <texPath>DBH/Things/Building/WB_fountainMarble</texPath>
        </graphicData>
        <costList Inherit="false">
          <Steel>5</Steel>
          <BlocksMarble>10</BlocksMarble>
        </costList>
        <stuffCategories Inherit="false">
        </stuffCategories>
        <costStuffCount>0</costStuffCount>
        <rotatable>true</rotatable>
      </ThingDef>
    </value>
  </Operation>

</Patch>