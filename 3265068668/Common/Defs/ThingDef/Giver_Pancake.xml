<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="MealCooked">
    <defName>WB_Giver_Pancake</defName>
    <label>giver's pancake</label>
    <description>A pancakes made with giver's milk. Please keep refrigerated.</description>
    <graphicData>
      <texPath>Things/Item/WB_Giver_Pancake</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MarketValue>30</MarketValue><!-- 売買の基本価格 -->
      <Mass>0.03</Mass><!-- 重さ -->
      <Nutrition>1.0</Nutrition><!-- 栄養 -->
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman><!-- 食中毒確率 -->
    </statBases>
    <tickerType>Rare</tickerType>
    <socialPropernessMatters>true</socialPropernessMatters>
    <ingestible>
      <preferability>MealLavish</preferability>
      <tasteThought>WB_Ate_Giver_Meals</tasteThought><!-- 食べた時に獲得する思考。つまり心情変動値はここに依存。 -->
      <baseIngestTicks>350</baseIngestTicks><!-- 完食にかかる時間。 -->
      <foodType>Meal</foodType><!-- 食品のカテゴリ -->
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
	  <ingestSound>Meal_Eat</ingestSound>
      <optimalityOffsetHumanlikes>32</optimalityOffsetHumanlikes><!-- 何を食べるか選ぶ際の基本優先度 -->
      <optimalityOffsetFeedingAnimals>1</optimalityOffsetFeedingAnimals>
    </ingestible>
  </ThingDef>
</Defs>