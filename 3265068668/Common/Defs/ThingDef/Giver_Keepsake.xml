<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef Name="WB_Giver_KeepsakeBase" Abstract="True">
    <thingClass>ThingWithComps</thingClass>
    <category>Item</category>
    <tradeability>None</tradeability>
    <generateCommonality>0</generateCommonality>
    <generateAllowChance>0</generateAllowChance>
    <drawerType>MapMeshOnly</drawerType>
    <selectable>True</selectable>
    <pathCost>5</pathCost>
    <useHitPoints>True</useHitPoints>
    <techLevel>Neolithic</techLevel>
    <rotatable>false</rotatable>
    <drawGUIOverlay>true</drawGUIOverlay>
    <statBases>
      <MaxHitPoints>10</MaxHitPoints>
      <Flammability>0.8</Flammability>
      <DeteriorationRate>0.5</DeteriorationRate>
      <Beauty>5</Beauty>
    </statBases>
    <altitudeLayer>Item</altitudeLayer>
    <alwaysHaulable>True</alwaysHaulable>
    <burnableByRecipe>true</burnableByRecipe>
    <smeltable>false</smeltable>
    <stackLimit>1</stackLimit>
    <tickerType>Rare</tickerType>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li>
        <compClass>CompColorable</compClass>
      </li>
    </comps>
    <allowedArchonexusCount>5</allowedArchonexusCount>
  </ThingDef>

  <ThingDef ParentName="WB_Giver_KeepsakeBase" Name="WB_Giver_Doll">
    <defName>WB_Giver_Doll</defName>
    <label>poorly crafted doll</label>
    <description>just junk.</description>
    <thingClass>seekiworks_GiverTheColonyHelper.WB_Keepsake</thingClass>
    <drawerType>RealtimeOnly</drawerType>
    <tickerType>Normal</tickerType>
    <graphicData>
      <texPath>Things/Item/Keepsake/WB_Giver_Doll</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_KeepsakeAdditionalField">
        <anotherGraphicTexPath>Things/Item/Keepsake/WB_Giver_DollTragically</anotherGraphicTexPath>
      </li>
    </modExtensions>
    <statBases>
      <MarketValue>1</MarketValue>
      <Mass>0.2</Mass>
      <Beauty>-5</Beauty>
    </statBases>
    <comps>
    </comps>
    <thingCategories Inherit="false">
      <li>Items</li>
    </thingCategories>
  </ThingDef>

</Defs>