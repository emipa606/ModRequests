<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="OrganicProductBase">
    <defName>WB_Giver_Milk</defName>
    <label>giver's milk</label>
    <description>Very delicious giver's milk. Even infants can drink it without worrying about food poisoning. Please keep refrigerated.</description>
    <graphicData>
      <texPath>Things/Item/WB_Giver_Milk</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MarketValue>1.9</MarketValue>
      <!-- Can be used like meat in recipes -->
      <Mass>0.045</Mass>
      <MaxHitPoints>80</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <Nutrition>0.1</Nutrition>
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman>
    </statBases>
    <tickerType>Rare</tickerType>
    <socialPropernessMatters>true</socialPropernessMatters>
    <thingCategories>
      <li>AnimalProductRaw</li>
    </thingCategories>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>4</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <ingestible>
      <preferability>RawTasty</preferability>
      <tasteThought>WB_DrinkedGiver_Milk</tasteThought><!-- 食べた時に獲得する思考。つまり心情変動値はここに依存。 -->
      <foodType>AnimalProduct, Fluid</foodType>
      <babiesCanIngest>true</babiesCanIngest>
      <optimalityOffsetHumanlikes>0</optimalityOffsetHumanlikes><!-- 何を食べるか選ぶ際の基本優先度 -->
      <optimalityOffsetFeedingAnimals>-5</optimalityOffsetFeedingAnimals>
    </ingestible>
    <allowedArchonexusCount>80</allowedArchonexusCount>
  </ThingDef>
</Defs>