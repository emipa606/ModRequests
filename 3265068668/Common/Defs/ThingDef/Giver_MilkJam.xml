<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="MealBase">
    <defName>WB_Giver_MilkJam</defName>
    <label>giver's milk jam</label>
    <description>Jam made with giver's milk. It can be stored for a long time even at room temperature.\nThis meal cannot cause food poisoning due to complete sterilization during cooking.</description>
    <graphicData>
      <texPath>Things/Item/WB_Giver_MilkJam</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MarketValue>30</MarketValue><!-- 売買の基本価格 -->
      <Mass>0.02</Mass><!-- 重さ -->
      <Nutrition>0.7</Nutrition><!-- 栄養 -->
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman><!-- 食中毒確率 -->
    </statBases>
    <tickerType>Rare</tickerType>
    <socialPropernessMatters>true</socialPropernessMatters>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>70</daysToRotStart><!-- 70日で腐るよ -->
        <rotDestroys>true</rotDestroys>
      </li>
      <li Class="CompProperties_Ingredients">
        <noIngredientsFoodKind>NonMeat</noIngredientsFoodKind>
      </li>
      <li Class="seekiworks_GiverTheColonyHelper.CompProperties_WB_NeverFoodPoisonMeal"/>
    </comps>
    <ingestible>
      <preferability>MealLavish</preferability>
      <tasteThought>WB_Ate_Giver_Meals</tasteThought><!-- 食べた時に獲得する思考。つまり心情変動値はここに依存。 -->
      <babiesCanIngest>true</babiesCanIngest>
      <baseIngestTicks>280</baseIngestTicks><!-- 完食にかかる時間。 -->
      <foodType>VegetableOrFruit, Fluid</foodType><!-- 食品のカテゴリ -->
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
      <ingestSound>Meal_Eat</ingestSound>
      <optimalityOffsetHumanlikes>16</optimalityOffsetHumanlikes><!-- 何を食べるか選ぶ際の基本優先度 -->
      <optimalityOffsetFeedingAnimals>1</optimalityOffsetFeedingAnimals>
      </ingestible>
  </ThingDef>
</Defs>