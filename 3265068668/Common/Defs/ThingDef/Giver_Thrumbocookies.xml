<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="MealBase">
    <defName>WB_Giver_Thrumbocookies</defName>
    <label>thrumbocookies</label>
    <description>Giant Slambo-shaped cookies made with giver's milk. They can be stored for a long time even at room temperature.</description>
    <graphicData>
      <texPath>Things/Item/WB_Giver_Thrumbocookies</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>30</MarketValue><!-- 売買の基本価格 -->
      <Mass>0.017</Mass><!-- 重さ -->
      <Nutrition>1.5</Nutrition><!-- 栄養 -->
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman><!-- 食中毒確率 -->
    </statBases>
    <tickerType>Rare</tickerType>
    <socialPropernessMatters>true</socialPropernessMatters>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>70</daysToRotStart><!-- 70日で腐るよ -->
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <ingestible>
      <preferability>MealLavish</preferability>
      <tasteThought>WB_Ate_Giver_Meals</tasteThought><!-- 食べた時に獲得する思考。つまり心情変動値はここに依存。 -->
      <baseIngestTicks>320</baseIngestTicks><!-- 完食にかかる時間。 -->
      <foodType>Meal</foodType><!-- 食品のカテゴリ -->
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
	  <ingestSound>Meal_Eat</ingestSound>
      <optimalityOffsetHumanlikes>0</optimalityOffsetHumanlikes><!-- 何を食べるか選ぶ際の基本優先度 -->
      <optimalityOffsetFeedingAnimals>1</optimalityOffsetFeedingAnimals>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>WB_SatietyOfThrumbocookies</hediffDef><!-- 食べた時に得るHediffの指定 -->
        </li>
      </outcomeDoers>
    </ingestible>
  </ThingDef>
</Defs>