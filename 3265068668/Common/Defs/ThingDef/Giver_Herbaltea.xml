<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="MealCooked" Name="WB_Giver_Herbaltea">
    <defName>WB_Giver_Herbaltea</defName>
    <label>giver's herbal tea</label>
    <description>Specially prepared herbal tea by giver. It has a recreational effect, provides a 3-day restful sleep effect, and speeds up the healing of injuries and illnesses. Please keep refrigerated.</description>
    <graphicData>
      <texPath>Things/Item/WB_Giver_Herbaltea</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MarketValue>2.4</MarketValue><!-- 売買の基本価格 -->
      <Mass>0.027</Mass><!-- 重さ -->
      <Nutrition>0.1</Nutrition><!-- 栄養 -->
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman><!-- 食中毒確率 -->
    </statBases>
    <stackLimit>75</stackLimit>
    <tickerType>Rare</tickerType>
    <socialPropernessMatters>true</socialPropernessMatters>
    <comps>
      <li Class="CompProperties_Drug">
      </li>
    </comps>
    <thingCategories Inherit="false">
      <li>FoodMeals</li>
    </thingCategories>
    <ingestible>
      <preferability>DesperateOnlyForHumanlikes</preferability>
      <drugCategory>Medical</drugCategory>
      <tasteThought>WB_DrinkedGiver_Herbaltea</tasteThought><!-- 食べた時に獲得する思考。つまり心情変動値はここに依存。 -->
      <joy>0.25</joy><!-- 娯楽回復量 -->
      <joyKind>Gluttonous</joyKind>
      <nurseable>true</nurseable><!-- 気絶している患者に投与できるか -->
      <baseIngestTicks>210</baseIngestTicks><!-- 完食にかかる時間。とりあえずサイカイトティーと同じにしたよ。 -->
      <foodType>VegetableOrFruit, Fluid</foodType>
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
      <optimalityOffsetHumanlikes>3</optimalityOffsetHumanlikes><!-- 何を食べるか選ぶ際の基本優先度 -->
      <optimalityOffsetFeedingAnimals>-30</optimalityOffsetFeedingAnimals>
      <outcomeDoers Inherit="false">
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>WB_EfficacyOfGiversHerbalTea</hediffDef><!-- 食べた時に得るHediffの指定 -->
          <severity>0.9</severity>
        </li>
      </outcomeDoers>
      <ingestSound>Ingest_Drink</ingestSound>
    </ingestible>
    <storedConceptLearnOpportunity>DrugPolicies</storedConceptLearnOpportunity>
    <orderedTakeGroup>Drug</orderedTakeGroup>
  </ThingDef>
</Defs>