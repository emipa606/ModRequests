<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="MealCooked">
    <defName>WB_Giver_Milkshake</defName>
    <label>giver's milkshake</label>
    <description>A milkshake made with giver's milk. Please keep refrigerated.This can be stacked at 75 per cell.</description>
    <graphicData>
      <texPath>Things/Item/WB_Giver_Milkshake</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MarketValue>2.25</MarketValue><!-- 売買の基本価格 -->
      <Mass>0.015</Mass><!-- 重さ -->
      <Nutrition>0.6</Nutrition><!-- 栄養 -->
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman><!-- 食中毒確率 -->
    </statBases>
    <stackLimit>75</stackLimit>
    <tickerType>Rare</tickerType>
    <socialPropernessMatters>true</socialPropernessMatters>
    <ingestible>
      <preferability>MealLavish</preferability>
      <tasteThought>WB_Ate_Giver_Meals</tasteThought><!-- 食べた時に獲得する思考。つまり心情変動値はここに依存。 -->
      <baseIngestTicks>210</baseIngestTicks><!-- 完食にかかる時間。 -->
      <foodType>VegetableOrFruit, Fluid</foodType><!-- 食品のカテゴリ -->
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
      <ingestSound>Ingest_Drink</ingestSound>
      <optimalityOffsetHumanlikes>32</optimalityOffsetHumanlikes><!-- 何を食べるか選ぶ際の基本優先度 -->
      <optimalityOffsetFeedingAnimals>1</optimalityOffsetFeedingAnimals>
    </ingestible>
  </ThingDef>
</Defs>