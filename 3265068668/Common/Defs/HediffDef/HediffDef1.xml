<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>WB_SatietyOfThrumbocookies</defName>
    <label>satiety of giver's thrumbocookies</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>I'm very full. I don't think I'll be hungry for a while.</description>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <maxSeverity>1</maxSeverity>
    <defaultLabelColor>(1.0, 1.0, 1.0)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-12</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <hungerRateFactor>0.01</hungerRateFactor>
      </li>
    </stages>
  </HediffDef>
  
  <HediffDef>
    <defName>WB_AdrenalineExcitement</defName>
    <hediffClass>seekiworks_GiverTheColonyHelper.WB_Hediff_TagExclusive</hediffClass>
    <label>adrenaline excitement</label>
    <description>excited to feel danger.</description>
    <defaultLabelColor>(1,0,0)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <stages>
      <li>
        <label>minor</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <label>serious</label>
        <becomeVisible>false</becomeVisible>
        <minSeverity>0.9</minSeverity>
        <painFactor>0.5</painFactor>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <setMax>1</setMax>
            <offset>3.00</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.20</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-12</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>

    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_HediffDefAdditionalField">
        <groupTag>emotion</groupTag><!-- 排他グループ名 -->
      </li>
    </modExtensions>

  </HediffDef>

  <HediffDef>
    <defName>WB_InAGoodMood</defName>
    <hediffClass>seekiworks_GiverTheColonyHelper.WB_Hediff_TagExclusive</hediffClass>
    <label>in a good mood</label>
    <description>The Giver seems to be in a good mood today.</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-4</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>

    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_HediffDefAdditionalField">
        <groupTag>emotion</groupTag><!-- 排他グループ名 -->
      </li>
    </modExtensions>

  </HediffDef>

  <HediffDef>
    <defName>WB_InLowSpirits</defName>
    <hediffClass>seekiworks_GiverTheColonyHelper.WB_Hediff_TagExclusive</hediffClass>
    <label>in low spirits</label>
    <description>The Giver seems to be in low spirits today.</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-6</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.5</postFactor>
          </li>
        </capMods>
      </li>
    </stages>

    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_HediffDefAdditionalField">
        <groupTag>emotion</groupTag><!-- 排他グループ名 -->
      </li>
    </modExtensions>

  </HediffDef>

  
  <HediffDef>
    <defName>WB_GiversBlessing</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>giver's blessing</label>
    <description>I feel very comfortable.</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <stages>
      <li>
        <label>minor</label>
        <becomeVisible>false</becomeVisible>
        <statOffsets>
         <ComfyTemperatureMax>2000</ComfyTemperatureMax>
         <ComfyTemperatureMin>-2000</ComfyTemperatureMin>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-24</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>WB_StillHalfAsleepy</defName>
    <hediffClass>seekiworks_GiverTheColonyHelper.WB_Hediff_TagExclusive</hediffClass>
    <label>still half asleep</label>
    <description>mumble mumble...</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-100</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.7</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.5</postFactor>
          </li>
        </capMods>
      </li>
    </stages>

    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_HediffDefAdditionalField">
        <groupTag>emotion</groupTag><!-- 排他グループ名 -->
      </li>
    </modExtensions>

  </HediffDef>

  <HediffDef>
    <defName>WB_EarlyBird</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>early bird</label>
    <description>early bird.</description>
    <defaultLabelColor>(1,1,1)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <stages>
      <li>
        <label>minor</label>
        <becomeVisible>false</becomeVisible>
        <statFactors>
          <RestRateMultiplier>10</RestRateMultiplier>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-24</severityPerDay>
        <showHoursToRecover>false</showHoursToRecover>
      </li>
    </comps>
  </HediffDef>

</Defs>
  