<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <FleckDef ParentName="FleckBase" Name="WB_Onpu">
    <defName>WB_Onpu</defName>
    <graphicData>
      <texPath>Things/Mote/WB_onpu</texPath>
    </graphicData>
    <fleckSystemClass>seekiworks_GiverTheColonyHelper.WB_FleckSystemSwayingThrown</fleckSystemClass>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <fadeInTime>0.08</fadeInTime>
    <solidTime>1.0</solidTime>
    <fadeOutTime>1.5</fadeOutTime>
    <growthRate>0.33</growthRate>
    <acceleration>(-0.6,0,-0.6)</acceleration>

    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_FleckSwayingThrownSetting">
        <swingPeriod>2</swingPeriod><!-- 1往復にかかる秒数 -->
        <swingAmplitude>20</swingAmplitude><!-- 最大揺れ角度（度 -->
      </li>
    </modExtensions>
  </FleckDef>

  <FleckDef ParentName="WB_Onpu">
    <defName>WB_Onpu2</defName>
    <graphicData>
      <texPath>Things/Mote/WB_onpu2</texPath>
    </graphicData>

    <modExtensions>
      <li Class="seekiworks_GiverTheColonyHelper.WB_FleckSwayingThrownSetting">
        <swingPeriod>2</swingPeriod><!-- 1往復にかかる秒数 -->
        <swingAmplitude>10</swingAmplitude><!-- 最大揺れ角度（度 -->
      </li>
    </modExtensions>

  </FleckDef>

</Defs>