<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThoughtDef>
    <defName>WB_DrinkedGiver_Herbaltea</defName>
    <durationDays>3</durationDays><!-- 思考の持続日数 -->
    <stages>
      <li>
        <label>WBDrinkedGiverHerbaltea</label>
        <description>I drank delicious tea.</description>
        <baseMoodEffect>5</baseMoodEffect><!-- 心情変動値 -->
      </li>
    </stages>
  </ThoughtDef>
  
  
  <ThoughtDef>
    <defName>WB_DrinkedGiver_Milk</defName>
    <durationDays>1</durationDays><!-- 思考の持続日数 -->
    <stages>
      <li>
        <label>WBDrinkedGiverMilk</label>
        <description>I dranked delicious milk.</description>
        <baseMoodEffect>2</baseMoodEffect><!-- 心情変動値 -->
      </li>
    </stages>
  </ThoughtDef>
  
  <ThoughtDef>
    <defName>WB_Ate_Giver_Meals</defName>
    <durationDays>1</durationDays><!-- 思考の持続日数 -->
    <stages>
      <li>
        <label>WBAteGiverMeals</label>
        <description>That was a very delicious dish. I want to eat that again.</description>
        <baseMoodEffect>10</baseMoodEffect><!-- 心情変動値 -->
      </li>
    </stages>
  </ThoughtDef>
  
  <ThoughtDef>
    <defName>WB_LaughingGiver</defName>
    <icon>icon/givericon</icon>
    <durationDays>0.25</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>giver laughing</label>
        <description>My heart was healed by the laughing giver.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  
  <ThoughtDef>
    <defName>WB_LaughingMyGiver</defName>
    <icon>icon/givericon</icon>
    <durationDays>0.25</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>my giver laughing</label>
        <description>My Giver, a paragon of adorableness, reigns supreme in the realm of cuteness!</description>
        <baseMoodEffect>6</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  
  <ThoughtDef>
    <defName>WB_BeSnuggledByGiver</defName>
    <icon>icon/givericon</icon>
    <durationDays>0.5</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>giver was snuggling me</label>
        <description>Adorable giver snuggled up to me affectionately. It made my heart flutter.</description>
        <baseMoodEffect>6</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  
  <ThoughtDef>
    <defName>WB_BeSnuggledByMyGiver</defName>
    <icon>icon/givericon</icon>
    <durationDays>0.5</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>my giver was snuggling me</label>
        <description>The lonely my giver came to me for affection again. With a beaming smile, I thought "Well, I can't help it" as I embraced her.</description>
        <baseMoodEffect>8</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  
  <ThoughtDef>
    <defName>WB_BondedGiverDied</defName>
    <thoughtClass>seekiworks_GiverTheColonyHelper.WB_Thought_Memory_BondedGiverDied</thoughtClass>
    <showBubble>true</showBubble>
    <durationDays>120</durationDays>
    <stackLimit>5</stackLimit>
    <stackLimitForSameOtherPawn>1</stackLimitForSameOtherPawn>
    <nullifyingTraits>
      <li>Psychopath</li>
    </nullifyingTraits>
    <stages>
      <li>
        <label>my dear {0} died</label>
        <description>It's painful, so painful, so very painful...</description>
        <baseMoodEffect>-12</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
  