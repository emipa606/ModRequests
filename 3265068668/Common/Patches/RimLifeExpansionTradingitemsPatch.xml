<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>RimLife Expansion Trading items</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationAddModExtension">
          <xpath>/Defs/ThingDef[defName="RLE_BerryMilk"]</xpath>
          <value>
            <li Class="seekiworks_GiverTheColonyHelper.WB_FoodAdditionalField">
              <isGiversFavoriteFood>true</isGiversFavoriteFood>
            </li>
          </value>
        </li>

        <li Class="PatchOperationAddModExtension">
          <xpath>/Defs/ThingDef[defName="RLE_driedBerry"]</xpath>
          <value>
            <li Class="seekiworks_GiverTheColonyHelper.WB_FoodAdditionalField">
              <isGiversFavoriteFood>true</isGiversFavoriteFood>
            </li>
          </value>
        </li>
      </operations>
    </match>
  </Operation>

</Patch>