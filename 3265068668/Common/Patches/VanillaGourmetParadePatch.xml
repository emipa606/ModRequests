<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Vanilla Gourmet Parade</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationAddModExtension">
          <xpath>/Defs/ThingDef[defName="VAGPRicecakefilled"]</xpath>
          <value>
            <li Class="seekiworks_GiverTheColonyHelper.WB_FoodAdditionalField">
              <isGiversFavoriteFood>true</isGiversFavoriteFood>
            </li>
          </value>
        </li>

        <li Class="PatchOperationAddModExtension">
          <xpath>/Defs/ThingDef[defName="VAGPBerrypie"]</xpath>
          <value>
            <li Class="seekiworks_GiverTheColonyHelper.WB_FoodAdditionalField">
              <isGiversFavoriteFood>true</isGiversFavoriteFood>
            </li>
          </value>
        </li>

      </operations>
    </match>
  </Operation>

</Patch>