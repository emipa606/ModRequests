<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>No Water, No Life (Continued)</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationInsert">
          <xpath>*/ThinkTreeDef[defName = "WB_SatisfyBasicNeeds"]/thinkRoot[@Class="ThinkNode_Tagger"]/subNodes/li[@Class="ThinkNode_PrioritySorter"]/subNodes//li[2]</xpath>
          <value>
            <li Class="MizuMod.JobGiver_GetWater" />
          </value>
        </li>

        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="WB_Giver_Milk"]/comps</xpath>
          <value>
              <li Class="MizuMod.CompProperties_WaterSource">
                <sourceType>Item</sourceType>
                <getSound>Ingest_Drink</getSound>
                <baseDrinkTicks>100</baseDrinkTicks>
                <waterType>NormalWater</waterType>
                <needManipulate>true</needManipulate>
                <waterAmount>0.05</waterAmount>
                <maxNumToGetAtOnce>1</maxNumToGetAtOnce>
                <waterVolume>0.5</waterVolume>
              </li>
          </value>
        </li>

        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="WB_Giver_Herbaltea"]/comps</xpath>
          <value>
              <li Class="MizuMod.CompProperties_WaterSource">
                <sourceType>Item</sourceType>
                <getSound>Ingest_Drink</getSound>
                <baseDrinkTicks>100</baseDrinkTicks>
                <waterType>NormalWater</waterType>
                <needManipulate>true</needManipulate>
                <waterAmount>0.5</waterAmount>
                <maxNumToGetAtOnce>1</maxNumToGetAtOnce>
                <waterVolume>0.5</waterVolume>
              </li>
          </value>
        </li>

        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="WB_Giver_Milkherbaltea"]/comps</xpath>
          <value>
              <li Class="MizuMod.CompProperties_WaterSource">
                <sourceType>Item</sourceType>
                <getSound>Ingest_Drink</getSound>
                <baseDrinkTicks>100</baseDrinkTicks>
                <waterType>NormalWater</waterType>
                <needManipulate>true</needManipulate>
                <waterAmount>0.5</waterAmount>
                <maxNumToGetAtOnce>1</maxNumToGetAtOnce>
                <waterVolume>0.5</waterVolume>
              </li>
          </value>
        </li>

        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="WB_Giver_Milkshake"]/comps</xpath>
          <value>
              <li Class="MizuMod.CompProperties_WaterSource">
                <sourceType>Item</sourceType>
                <getSound>Ingest_Drink</getSound>
                <baseDrinkTicks>100</baseDrinkTicks>
                <waterType>NormalWater</waterType>
                <needManipulate>true</needManipulate>
                <waterAmount>0.5</waterAmount>
                <maxNumToGetAtOnce>1</maxNumToGetAtOnce>
                <waterVolume>0.5</waterVolume>
              </li>
          </value>
        </li>

      </operations>
    </match>
  </Operation>

</Patch>