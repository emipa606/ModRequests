<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>VGP Vegetable Garden</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationReplace">
          <xpath>/Defs/ThingDef[defName="WB_Giver_Berrycompote"]/graphicData/texPath</xpath>
          <value>
            <texPath>Things/Item/WB_Giver_Berrycompote2</texPath>
          </value>
        </li>

        <li Class="PatchOperationReplace">
          <xpath>/Defs/ThingDef[defName="WB_Giver_Berrycompotetart"]/graphicData/texPath</xpath>
          <value>
            <texPath>Things/Item/WB_Giver_Berrycompotetart2</texPath>
          </value>
        </li>

        <li Class="PatchOperationReplace">
          <xpath>/Defs/RecipeDef[defName="WB_Cook_WB_Giver_Berrycompote"]/ingredients/li/count</xpath>
          <value>
            <count>4.8</count>
          </value>
        </li>

        <li Class="PatchOperationReplace">
          <xpath>/Defs/RecipeDef[defName="WB_Cook_WB_Giver_Berrycompotetart"]/ingredients/li[filter/thingDefs/li="RawBerries"]/count</xpath>
          <value>
            <count>0.32</count>
          </value>
        </li>

        <li Class="PatchOperationReplace">
          <xpath>/Defs/RecipeDef[defName="WB_Cook_WB_Giver_Berrytart"]/ingredients/li[filter/thingDefs/li="RawBerries"]/count</xpath>
          <value>
            <count>0.64</count>
          </value>
        </li>

      </operations>
    </match>
  </Operation>

</Patch>