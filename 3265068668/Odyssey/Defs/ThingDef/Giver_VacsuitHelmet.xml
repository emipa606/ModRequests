<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="ApparelNoQualityBase" MayRequire="Ludeon.RimWorld.Odyssey">
    <defName>WB_Giver_KumachanVacsuitHelmet</defName>
    <label>bearly vacsuit helmet</label>
    <description>A cute teddy bear vacuum helmet that Giver likes. With this, you can easily survive in space. Be careful, it's fragile.</description><!-- Giver好みな可愛らしいクマちゃん真空ヘルメット。これさえあれば宇宙空間でもへっちゃら。壊れやすいので注意。 -->
    <thingClass>seekiworks_GiverTheColonyHelper.WB_TranslucentApparel</thingClass>
    <thingCategories>
      <li>WB_Giveracc</li>
      <li>ArmorHeadgear</li>
    </thingCategories>
    <tickerType>Long</tickerType>
    <possessionCount>1</possessionCount>
    <techLevel>Medieval</techLevel>
    <generateCommonality>0</generateCommonality>
    <generateAllowChance>0</generateAllowChance>
    <graphicData>
      <texPath>Things/Item/Vacsuit/WB_GiverKumachanVacsuitHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>Transparent</shaderType>
      <renderQueue>2950</renderQueue>
      <onGroundRandomRotateAngle>0</onGroundRandomRotateAngle>
    </graphicData>
    <statBases>
      <WorkToMake>10000</WorkToMake>
      <MaxHitPoints>60</MaxHitPoints>
      <Mass>1.0</Mass>
      <MarketValue>1000</MarketValue>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.3</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.2</ArmorRating_Blunt>
      <ArmorRating_Heat>0.2</ArmorRating_Heat>
      <Insulation_Cold>100</Insulation_Cold>
      <Insulation_Heat>20</Insulation_Heat>
      <EquipDelay>5</EquipDelay>
      <DeteriorationRate>0</DeteriorationRate>
      <Beauty>50</Beauty>
    </statBases>
    <tradeability>Buyable</tradeability>
    <equippedStatOffsets>
      <ToxicEnvironmentResistance>1.0</ToxicEnvironmentResistance>
      <VacuumResistance>1.0</VacuumResistance>
      <MoveSpeed>-0.05</MoveSpeed>
      <DecompressionResistance MayRequire="kentington.saveourship2">1.0</DecompressionResistance>
      <HypoxiaResistance MayRequire="kentington.saveourship2">1.0</HypoxiaResistance>
    </equippedStatOffsets>
    <smeltable>false</smeltable>
    <apparel>
      <parentTagDef>ApparelHead</parentTagDef>
      <countsAsClothingForNudity>true</countsAsClothingForNudity>
      <developmentalStageFilter>Child, Adult</developmentalStageFilter>
      <immuneToToxGasExposure>true</immuneToToxGasExposure>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <bodyPartGroups Inherit="false">
        <li>FullHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Item/Vacsuit/WB_GiverKumachanVacsuitHelmet</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags Inherit="false">
        <li>WB_Giver</li>
      </tags>
      <renderSkipFlags>
        <li>None</li>
      </renderSkipFlags>
      <forceEyesVisibleForRotations>
        <li>1</li>
        <li>2</li>
        <li>3</li>
      </forceEyesVisibleForRotations>
      <defaultOutfitTags>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <drawData>
        <defaultData>
          <layer>88</layer>
          <offset>(0, 0, -0.02)</offset>
        </defaultData>
        <scale>1.05</scale>
      </drawData>
    </apparel>
    <comps>
      <li Class="seekiworks_GiverTheColonyHelper.CompProperties_GiverLinkedHediffApparel">
        <hediffs>
          <li>WB_KumachanCylinder</li>
          <li>WB_OxygenRibbonBrooch</li>
        </hediffs>
        <parts>
          <li>Body</li>
          <li>Body</li>
        </parts>
      </li>
    </comps>
    <tradeTags>
    </tradeTags>
    <thingSetMakerTags>
      <li>Reward_AncientBox_ComponentSpacer</li>
    </thingSetMakerTags>
  </ThingDef>

</Defs>