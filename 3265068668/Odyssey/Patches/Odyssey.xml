<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Add parts field to StatDef VacuumResistance if it doesn't exist -->
    <Operation Class="PatchOperationConditional">
        <xpath>*/StatDef[defName="VacuumResistance"]/parts</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>*/StatDef[defName="VacuumResistance"]</xpath>
            <success>Always</success>
            <value>
                <parts></parts>
            </value>
        </nomatch>
    </Operation>

    <Operation Class="PatchOperationConditional">
        <xpath>*/StatDef[defName="VacuumResistance"]/parts</xpath>
        <match Class="PatchOperationAdd">
            <xpath>*/StatDef[defName="VacuumResistance"]/parts</xpath>
            <value>
                <li Class="seekiworks_GiverTheColonyHelper.WB_StatPart_HitPoints"/>
            </value>
        </match>
    </Operation>

