  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Glass+Lights</li>
    </mods>
    <match Class="PatchOperationAdd">
      <xpath>*/ThingDef[defName="WB_Giver_KumachanVacsuitHelmet"]</xpath>
      <value>
        <costList>
          <Glass>5</Glass>
          <Cloth>15</Cloth>
          <Steel>3</Steel>
        </costList>
        <recipeMaker>
          <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
          <researchPrerequisite>ComplexClothing</researchPrerequisite>
          <useIngredientsForColor>false</useIngredientsForColor>
          <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
          <workSkill>Crafting</workSkill>
          <effectWorking>Smith</effectWorking>
          <soundWorking>Recipe_Smith</soundWorking>
          <skillRequirements>
            <Crafting>3</Crafting>
          </skillRequirements>
          <displayPriority>320</displayPriority>
          <recipeUsers>
            <li>FueledSmithy</li>
            <li>ElectricSmithy</li>
          </recipeUsers>
        </recipeMaker>
      </value>
    </match>
  </Operation>


  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Odyssey</li>
    </mods>
    <match Class="PatchOperationAdd">
      <xpath>*/TraderKindDef[defName="Orbital_BulkGoods"]/stockGenerators</xpath>
      <value>

        <li Class="StockGenerator_SingleDef">
          <thingDef>WB_Giver_KumachanVacsuitHelmet</thingDef>
          <countRange>-1~1</countRange><!-- 33% chance -->
        </li>

      </value>
    </match>
  </Operation>

