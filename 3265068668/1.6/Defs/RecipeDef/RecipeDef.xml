<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!--Giver_Berrytart-->
  <RecipeDef>
    <defName>WB_Cook_WB_Giver_Berrytart</defName>
    <label>bake giver's berry tart</label>
    <description>Bake giver's berry tart from giver's milk and ingredients.</description>
    <jobString>Baking giver's berry tart.</jobString>
    <workAmount>1900</workAmount><!--作業時間-->
    <workSpeedStat>CookSpeed</workSpeedStat>
    <requiredGiverWorkType>Cooking</requiredGiverWorkType>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_Cremate</soundWorking>
    <recipeUsers>
      <!--作業台-->
      <li>ElectricStove</li>
      <li>FueledStove</li>
      <li MayRequire="DankPyon.Medieval.Overhaul">DankPyon_StoneOven</li>
    </recipeUsers>
    <allowMixingIngredients>true</allowMixingIngredients>
    <ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
    <ingredients><!--原材料の指定はここ-->
      <li>
        <filter>
          <categories><!--カテゴリ指定-->
            <li>PlantFoodRaw</li>
          </categories>
        </filter>
        <count>0.9</count><!--必要な栄養合計。個数合計ではなく栄養合計。-->
      </li>
      <li>
        <filter>
          <thingDefs><!--名指し指定-->
            <li>WB_Giver_Milk</li>
          </thingDefs>
        </filter>
        <count>1.5</count>
      </li>
      <li>
        <filter>
          <categories><!--カテゴリ指定-->
            <li>EggsUnfertilized</li>
            <li>EggsFertilized</li>
          </categories>
        </filter>
        <count>0.5</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>RawBerries</li>
          </thingDefs>
        </filter>
        <count>0.4</count>
      </li>
    </ingredients>
    <products>
      <WB_Giver_Berrytart>4</WB_Giver_Berrytart><!--出来上がる物と量-->
    </products>
    <fixedIngredientFilter><!-- 必須条件を記述。特定の材料の排除もここ。 -->
      <categories><!--カテゴリ指定-->
        <li>PlantFoodRaw</li>
        <li>EggsUnfertilized</li>
        <li>EggsFertilized</li>
      </categories>
      <thingDefs><!--名指し指定-->
        <li>WB_Giver_Milk</li>
      </thingDefs>
    </fixedIngredientFilter>
    <defaultIngredientFilter><!-- チェックボックス初期設定を定義 -->
      <categories>
        <li>Foods</li>
      </categories>
      <disallowedCategories>
        <li>EggsFertilized</li>
      </disallowedCategories>
      <disallowedThingDefs>
        <li>RawFungus</li>
        <li>InsectJelly</li>
      </disallowedThingDefs>
    </defaultIngredientFilter>
    <workSkill>Cooking</workSkill>
  </RecipeDef>

