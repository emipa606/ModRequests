<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>VC_SB9A</defName>
    <label>SB9-1</label>
    <description>An anti-tank lance produced by the United States of Vinland's Federal Alchemic Company. Based on an less advanced model, the M2EQ, the SB9 features enhanced accuracy. Adapted for use by a single version thanks to its magazine. - Circa 1935</description>
<tickerType>Normal</tickerType>
    <techLevel>Industrial</techLevel>
    <graphicData>
      <texPath>SB9-1</texPath>
      <graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
    </graphicData>
    <statBases>
	<WorkToMake>40000</WorkToMake>
      <Mass>15.5</Mass>
      <RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>Gun</li>
      <li>GunHeavy</li>
    </weaponTags>
    <costList>
      <Steel>150</Steel>
      <ComponentIndustrial>10</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_SB9A</defaultProjectile>
		<forcedMissRadius>3.9</forcedMissRadius>
        <warmupTime>3</warmupTime>
		<ai_AvoidFriendlyFireRadius>2</ai_AvoidFriendlyFireRadius>
        <range>30.9</range>
        <soundCast>InfernoCannon_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <onlyManualCast>true</onlyManualCast>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>15</power>
        <cooldownTime>4</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>15</power>
        <cooldownTime>4</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_SB9A</defName>
    <label>SB9-1 Rocket</label>
    <graphicData>
      <texPath>Things/Projectile/Rocket_Big</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	<shaderType>TransparentPostLight</shaderType>
	</graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
      <damageDef>Bomb</damageDef>
	  <damageAmountBase>17</damageAmountBase>
      <explosionRadius>3.9</explosionRadius>
      <speed>55</speed>
    </projectile>
  </ThingDef>

</Defs>