<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="HatMakeableBase">
    <defName>VC_ImpH</defName>
    <label>Imperial Helmet</label>
    <description>A standard issue imperial helmet.</description>
	<techLevel>Industrial</techLevel>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
       <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>IHelmet/IHelmet_south</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.00</drawSize>
    </graphicData>
    <costList>
      <Cloth>10</Cloth>
      <Steel>100</Steel>
    </costList>
    <thingCategories>
      <li>Apparel</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>165</MaxHitPoints>
      <WorkToMake>2500</WorkToMake>
      <Mass>0.09</Mass>
      <Flammability>0.6</Flammability>
      <ArmorRating_Sharp>0.5</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
      <ArmorRating_Heat>0.25</ArmorRating_Heat>
      <Insulation_Cold>1.4</Insulation_Cold> <!-- like a cloth jacket -->
      <Insulation_Heat>3</Insulation_Heat>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>-0.15</MoveSpeed>
      <PainShockThreshold>0.15</PainShockThreshold>
			<SocialImpact>-0.25</SocialImpact>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <wornGraphicPath>IHelmet/IHelmet</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>IndustrialMilitaryBasic</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
  </ThingDef>
  


</Defs>