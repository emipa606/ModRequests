<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>VC_ZMSGC</defName>
    <label>ZM SG 3</label>
    <description>The ZM SG was based on an infantry gun carried by many of the Empire's soldiers during EW1, particularly noted for its firing accuracy. The SG also featured a Rudolf Co. variable small arms scope. Lauded for its accuracy and uncommonly shock-resistant barrel, it first saw use with the Empire's mountain ranger units. Though the ZM SG's design allowed for a bayonet to be affixed under the muzzle, there are very few instances of it being used during the Second Europan War. - Circa 1935</description>
    <graphicData>
      <texPath>ZM SG 3</texPath>
      <graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
    </graphicData>
    <soundInteract>Interact_Rifle</soundInteract>
    <recipeMaker>
      <researchPrerequisite>PrecisionRifling</researchPrerequisite>
      <skillRequirements>
        <Crafting>9</Crafting>
      </skillRequirements>
    </recipeMaker>
    <statBases>
      <WorkToMake>1000</WorkToMake>
      <Mass>3.98</Mass>
      <AccuracyTouch>0.40</AccuracyTouch>
      <AccuracyShort>0.65</AccuracyShort>
      <AccuracyMedium>0.80</AccuracyMedium>
      <AccuracyLong>0.85</AccuracyLong>
      <RangedWeapon_Cooldown>2.25</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>30</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
	  <VC_ZMSGB>1</VC_ZMSGB>
    </costList>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_ZMSGC</defaultProjectile>
        <warmupTime>3</warmupTime>
        <range>48.9</range>
        <soundCast>Shot_SniperRifle</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <weaponTags Inherit="False">
      <li>SniperRifle</li>
    </weaponTags>
  </ThingDef>
  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_ZMSGC</defName>
    <label>ZM SG 3 bullet</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Big</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>33</damageAmountBase>
      <stoppingPower>2.5</stoppingPower>
      <speed>100</speed>
    </projectile>
  </ThingDef>


</Defs>