<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="HatMakeableBase">
    <defName>VC_RileyHeadband</defName>
    <label>Riley's Headband</label>
    <description>Riley's custom headband.</description>
	<techLevel>Industrial</techLevel>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
       <skillRequirements>
        <Crafting>3</Crafting>
      </skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>VC4Riley/Riley_head_south</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.00</drawSize>
    </graphicData>
    <costList>
      <Cloth>20</Cloth>
      <Steel>5</Steel>
    </costList>
    <thingCategories>
      <li>Apparel</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>115</MaxHitPoints>
      <WorkToMake>1000</WorkToMake>
      <Mass>0.05</Mass>
      <Flammability>0.6</Flammability>
      <ArmorRating_Sharp>0.05</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.05</ArmorRating_Blunt>
      <ArmorRating_Heat>0.05</ArmorRating_Heat>
      <Insulation_Cold>0.1</Insulation_Cold> <!-- like a cloth jacket -->
      <Insulation_Heat>0.1</Insulation_Heat>
      <EquipDelay>1</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>0.10</MoveSpeed>
      <ResearchSpeed>0.15</ResearchSpeed>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>
      <wornGraphicPath>VC4Riley/Riley_head</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>IndustrialMilitaryBasic</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
        <li>Worker</li>
      </defaultOutfitTags>
    </apparel>
  </ThingDef>
  


</Defs>