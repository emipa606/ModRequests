<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>VC_LancaarA</defName>
    <label>Lancaar M1</label>
    <description>Gallia's most common anti-tank lance, developed as a way to allow foot soldiers to combat tanks unassisted. An armor-penetrating warhead is loaded into the lance's tip, then fired at the target, detonating on impact. Though its power and effectiveness is indisputable, its considerable weight impedes the mobility of the user. The weapon draws its name from its use as a LANCe-shaped Anti-ArmoR device. - Circa 1935</description>
<tickerType>Normal</tickerType>
    <techLevel>Industrial</techLevel>
    <graphicData>
      <texPath>Lancaar M1</texPath>
      <graphicClass>Graphic_Single</graphicClass>
			<drawSize>2</drawSize>
    </graphicData>
    <statBases>
	<WorkToMake>40000</WorkToMake>
      <Mass>13.5</Mass>
      <RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>Gun</li>
      <li>GunHeavy</li>
    </weaponTags>
    <costList>
      <Steel>135</Steel>
      <ComponentIndustrial>10</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_LancaarA</defaultProjectile>
		<forcedMissRadius>2.9</forcedMissRadius>
        <warmupTime>3</warmupTime>
		<ai_AvoidFriendlyFireRadius>2</ai_AvoidFriendlyFireRadius>
        <range>34.9</range>
        <soundCast>InfernoCannon_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <onlyManualCast>true</onlyManualCast>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>15</power>
        <cooldownTime>4</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>15</power>
        <cooldownTime>4</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_LancaarA</defName>
    <label>Lancaar M1 Rocket</label>
    <graphicData>
      <texPath>Things/Projectile/Rocket_Big</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	<shaderType>TransparentPostLight</shaderType>
	</graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
      <damageDef>Bomb</damageDef>
	  <damageAmountBase>20</damageAmountBase>
      <explosionRadius>2.9</explosionRadius>
      <speed>55</speed>
    </projectile>
  </ThingDef>

</Defs>