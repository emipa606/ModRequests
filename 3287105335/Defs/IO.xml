<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ArmorMachineableBase">
    <defName>VC_InfI</defName>
    <label>Imperial infantry outfit</label>
    <description>standard issue Imperial outfit, consisting of a brown outfit with a large armour vest on the front, a small backpack, armour plating on the arms, metal kneecaps, a tactial harness and black boots.</description>
    <recipeMaker>
      <researchPrerequisite>FlakArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>6</Crafting>
      </skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>InfI/ISJacket_Male_south</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.00</drawSize>
    </graphicData>
    <costList>
      <Cloth>200</Cloth>
      <Steel>125</Steel>
    </costList>
    <thingCategories>
      <li>Apparel</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>190</MaxHitPoints>
      <WorkToMake>16000</WorkToMake>
      <Mass>5</Mass>
      <Flammability>0.6</Flammability>
      <ArmorRating_Sharp>0.55</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.55</ArmorRating_Blunt>
      <ArmorRating_Heat>0.55</ArmorRating_Heat>
      <Insulation_Cold>6.4</Insulation_Cold> <!-- like a cloth jacket -->
      <Insulation_Heat>5</Insulation_Heat>
      <EquipDelay>6</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>-0.30</MoveSpeed>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>InfI/ISJacket</wornGraphicPath>
      <layers>
        <li>OnSkin</li>
        <li>Middle</li>
      </layers>
      <tags>
        <li>IndustrialAdvanced</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
  </ThingDef>


</Defs>