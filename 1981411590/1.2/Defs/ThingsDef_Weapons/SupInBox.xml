<?xml version="1.0" encoding="utf-8" ?>
<Defs>  
    <!-- Suprise Box -->
    <ThingDef ParentName="TrapIEDBase">
    <defName>Clown_SupriseBox</defName>
    <label>Suprise in a Box</label>
    <description>ChatterBOX.</description>
    <graphicData>
      <texPath>Things/Items/JinB</texPath>
    </graphicData>
		<recipeMaker>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
    <costList>
      <Steel>250</Steel>
      <Clown_SlipperyPDA>1</Clown_SlipperyPDA>
    </costList>
    <comps>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>4.9</explosiveRadius>
        <explosiveDamageType>Extinguish</explosiveDamageType>
        <startWickHitPointsPercent>0.2</startWickHitPointsPercent>
        <postExplosionSpawnThingDef>IncomingAnvil</postExplosionSpawnThingDef>
        <postExplosionSpawnChance>0.05</postExplosionSpawnChance>
        <postExplosionSpawnThingCount>1</postExplosionSpawnThingCount>
        <applyDamageToExplosionCellsNeighbors>false</applyDamageToExplosionCellsNeighbors>
        <preExplosionSpawnThingDef>Gas_Smoke</preExplosionSpawnThingDef>
        <preExplosionSpawnChance>1</preExplosionSpawnChance>
        <explosionEffect>ExtinguisherExplosion</explosionEffect>
        <explosionSound>BoxExplosion</explosionSound>
        <wickTicks>
          <min>15</min>
          <max>15</max>
        </wickTicks>
      </li>
    </comps>
    <specialDisplayRadius>4.9</specialDisplayRadius>
  </ThingDef>
  
    <!-- Anvil Drop -->
    <ThingDef ParentName="SkyfallerBase">
    <defName>IncomingAnvil</defName>
    <label>Anvil (incoming)</label>
    <size>(2, 2)</size>
    <graphicData>
      <texPath>Things/Items/Anvil</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>Transparent</shaderType>
      <drawSize>(4, 4)</drawSize>
    </graphicData>
    <skyfaller>
      <shadowSize>(3, 3)</shadowSize>
      <explosionRadius>4.9</explosionRadius>
      <explosionDamage>Bomb</explosionDamage>
      <rotateGraphicTowardsDirection>true</rotateGraphicTowardsDirection>
      <speed>1.0</speed>
      <cameraShake>1</cameraShake>
      <anticipationSound>AnvilFall</anticipationSound>
      <metalShrapnelCountRange><min>1</min><max>5</max></metalShrapnelCountRange>
      <rubbleShrapnelCountRange><min>100</min><max>300</max></rubbleShrapnelCountRange>
    </skyfaller>
  </ThingDef>
</Defs>