<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- ====================Tar Dog ========================== -->
  
  	<ThingDef ParentName="BaseGrenadeProjectile">
		<defName>Throw_TarDog</defName>
		<label>TarDog_Throw</label>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
			<texPath>Things/Items/dogtar</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<explosionRadius >1.9</explosionRadius >
			<damageDef>Stun</damageDef>
			<explosionDelay>1</explosionDelay>
			<postExplosionSpawnThingDef>Filth_Tar</postExplosionSpawnThingDef>
			<postExplosionSpawnChance>1</postExplosionSpawnChance>
			<postExplosionSpawnThingCount>2</postExplosionSpawnThingCount>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseMakeableGrenade">
		<defName>Clown_DogTar</defName>
		<label>Balloon Dog Tar Edition</label>
		<description>In Mother Rim, dog does not roll in the 'mud', the 'mud' rolls in the dog.</description>
    	<tickerType>Normal</tickerType>
		<graphicData>
			<texPath>Things/Items/dogtar</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_TarDog</soundInteract>
		<techLevel>Neolithic</techLevel>
		<recipeMaker>
			<recipeUsers>
				<li>TableMachining</li>
				<li>CraftingSpot</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<statBases>
			<Mass>1.2</Mass>
			<RangedWeapon_Cooldown>2.66</RangedWeapon_Cooldown>
    	<WorkToMake>12000</WorkToMake>
    	</statBases>
		<costList>
		  <Steel>50</Steel>
		  <Chemfuel>25</Chemfuel>
		</costList>
		<weaponTags>
			<li>ClownStuff</li>
		</weaponTags>
		<thingCategories>
			<li>Grenades</li>
		</thingCategories>
		<verbs>
			<li>
				<label>throw tar dog</label>
				<verbClass>Verb_LaunchProjectile</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<range>10.9</range>
				<forcedMissRadius>1.9</forcedMissRadius>
				<warmupTime>1.5</warmupTime>
				<noiseRadius>2</noiseRadius>
				<soundCast>ThrowGrenade</soundCast>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<defaultProjectile>Throw_TarDog</defaultProjectile>
				<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
			</li>
		</verbs>

	</ThingDef>
	
	<!-- Filth Tar -->
	<ThingDef ParentName="BaseFilth">
		<defName>Filth_Tar</defName>
		<label>Tar puddle</label>
		<description>A puddle of flammable tar.</description>
		<thingClass>LiquidFuel</thingClass>
		<useHitPoints>true</useHitPoints>
		<statBases>
			<Beauty>-20</Beauty>
			<Cleanliness>-35</Cleanliness>
			<MaxHitPoints>250</MaxHitPoints>
			<Flammability>3.0</Flammability>
		</statBases>
		<graphicData>
			<texPath>Things/Items/Tar</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<filth>
			<rainWashes>false</rainWashes>
			<cleaningWorkToReduceThickness>150</cleaningWorkToReduceThickness>
			<canFilthAttach>false</canFilthAttach>
			<maxThickness>5</maxThickness>
		</filth>
		<pathCost>100</pathCost>
		<pathCostIgnoreRepeat>false</pathCostIgnoreRepeat>
	</ThingDef>


	
</Defs>