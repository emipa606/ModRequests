<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<!--==================================== Balloon Sword ====================================-->

	<ThingDef ParentName="BaseMeleeWeapon_Sharp">
		<defName>Clown_BalloonSword</defName>
		<label>Balloon Sword</label>
		<description>This IRONICALLY has a COLD BLADE.</description>
		<techLevel>Neolithic</techLevel>
		<graphicData>
			<texPath>Things/Items/WSword</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_BSword</soundInteract>
		<costList>
			<Steel>200</Steel>
		</costList>
		<recipeMaker>
			<recipeUsers>
				<li>CraftingSpot</li>
				<li>TableMachining</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<weaponTags>
			<li>ClownStuff</li>
		</weaponTags>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<WorkToMake>1000</WorkToMake>
			<Mass>2</Mass>
		</statBases>
		
		<equippedStatOffsets>
			<MeleeHitChance>.15</MeleeHitChance>
		</equippedStatOffsets>


		<tools>
			<li>
				<label>length</label>
				<capacities>
					<li>Clown_BalloonSmash</li>
				</capacities>
				<power>10</power>
				<cooldownTime>3</cooldownTime>
			</li>
			<li>
				<label>handle</label>
				<capacities>
					<li>Clown_BalloonHit</li>
				</capacities>
				<power>5</power>
				<cooldownTime>1.5</cooldownTime>
			</li>
		</tools>
	</ThingDef>
	
	<DamageDef Parentname="BaseCut">
		<defName>Frosty</defName>
		<label>Coldibits</label>
		<workerClass>DamageWorker_Frostbite</workerClass>
		<externalViolence>false</externalViolence>
		<deathMessage>{0} has succumbed to being very very cold.</deathMessage>
		<hediff>Frostbite</hediff>
		<harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
		<canUseDeflectMetalEffect>false</canUseDeflectMetalEffect>
  	</DamageDef>

</Defs>