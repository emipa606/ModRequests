<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<FactionDef ParentName="HumanFactionBase" Name="Clown_Base_Common" Abstract="True">
		<pawnSingular>Clown</pawnSingular>
		<pawnsPlural>Clowns</pawnsPlural>
		<listOrderPriority>20</listOrderPriority>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<canMakeRandomly>true</canMakeRandomly>
		<canStageAttacks>true</canStageAttacks>
		<canSiege>true</canSiege>
		<factionIconPath>Things/Items/Clown_Icon</factionIconPath>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
		<geneticVariance>0.1</geneticVariance>
		<fixedName>Crazy Clown Posse</fixedName>
		<!--<factionNameMaker>PONamerFaction</factionNameMaker>-->
		<!--<settlementNameMaker>ClownNamerFaction</settlementNameMaker>-->
		<!--<pawnNameMaker>ClownNamer</pawnNameMaker>-->
		<hairTags>
		  <li>Rural</li>
		</hairTags>
		<techLevel>Industrial</techLevel>
		<backstoryFilters>
		  <li>
			<categories>
			  <li>Outlander</li>
			</categories>
			<commonality>0.50</commonality>
		  </li>
		  <li>
			<categories>
			  <li>Offworld</li>
			</categories>
			<commonality>0.50</commonality>
		  </li>
		</backstoryFilters>
		<leaderTitle>Big Red Nose</leaderTitle>
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 1)</li>
				<!--Constant 1 at all points levels-->
			</points>
		</raidCommonalityFromPointsCurve>
		<caravanTraderKinds>
			<li>Caravan_Clown_BulkGoods</li>
			<li>Caravan_Clown_CombatSupplier</li>
			<li>Caravan_Clown_PirateMerchant</li>
			<li>Caravan_Clown_Exotic</li>
		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>Visitor_Clown_Standard</li>
			<li>Caravan_Clown_BulkGoods</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Base_Clown_Standard</li>
		</baseTraderKinds>
		<allowedArrivalTemperatureRange>
			<min>-40</min>
			<max>45</max>
		</allowedArrivalTemperatureRange>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0,35)</li>
				<li>(70, 50)</li>
				<li>(800, 100)</li>
				<li>(1300, 150)</li>
				<li>(100000, 10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		
		<pawnGroupMakers>
			<li>
				<!-- Normal fights, ranged with melee mix-ins -->
				<kindDef>Combat</kindDef>
				<commonality>100</commonality>
				<options>
				  <Clown_Scout>25</Clown_Scout>
				  <Clown_Operator>10</Clown_Operator>
				</options>
			</li>
			<li>
				<!-- Peaceful -->
				<kindDef>Peaceful</kindDef>
				<options>
				  <Clown_Scout>10</Clown_Scout>
				</options>
			</li>
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<Clown_Trader>1</Clown_Trader>
				</traders>
				<carriers>
					<Muffalo>4</Muffalo>
				</carriers>
				<guards>
				  <Clown_Scout>10</Clown_Scout>
				  <Clown_Operator>2</Clown_Operator>
				</guards>
			</li>
			
			<li>
				<!-- Settlement. -->
				<kindDef>Settlement</kindDef>
				<options>
				  <Clown_Scout>30</Clown_Scout>
				  <Clown_Operator>30</Clown_Operator>
				</options>
			</li>
		</pawnGroupMakers>
	</FactionDef>

	<FactionDef ParentName="Clown_Base_Common">
		<defName>ClownBase</defName>
		<label>Clown Base</label>
		<description>It's just a party in here.</description>
		<colorSpectrum>
		  <li>(255, 51, 153)</li>
		  <li>(178, 102, 255)</li>
		</colorSpectrum>
		<startingGoodwill>
		  <min>-80</min>
		  <max>20</max>
		</startingGoodwill>
		<naturalColonyGoodwill>
		  <min>-20</min>
		  <max>20</max>
		</naturalColonyGoodwill>
	</FactionDef>
</Defs>