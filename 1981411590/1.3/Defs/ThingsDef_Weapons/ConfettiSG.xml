<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseBullet">
    <defName>ConfettiRound</defName>
    <label>Confetti Blast</label>
    <graphicData>
      <texPath>Things/Items/ConfettiBuck</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Flame</damageDef>
      <damageAmountBase>18</damageAmountBase>
      <stoppingPower>2</stoppingPower>
      <armorPenetrationBase>0.25</armorPenetrationBase>
      <speed>55</speed>
    </projectile>
  </ThingDef>

<ThingDef ParentName="BaseHumanMakeableGun">
    <defName>Clown_ConfettiGun</defName>
    <label>Confetti Popper</label>
    <description>It's my party and i'll POP if I want to.</description>
    <graphicData>
      <texPath>Things/Items/ConfettiSG</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_Confetti</soundInteract>
    <statBases>
      <WorkToMake>800</WorkToMake>
      <Mass>1.5</Mass>
      <AccuracyTouch>0.80</AccuracyTouch>
      <AccuracyShort>0.87</AccuracyShort>
      <AccuracyMedium>0.77</AccuracyMedium>
      <AccuracyLong>0.64</AccuracyLong>
      <RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>60</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
		<recipeMaker>
			<recipeUsers>
				<li>TableMachining</li>
				<li>CraftingSpot</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<techLevel>Neolithic</techLevel>
 		<weaponTags>
			<li>ClownStuff</li>
		</weaponTags>   
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ConfettiRound</defaultProjectile>
        <warmupTime>0.9</warmupTime>
        <range>15.9</range>
        <soundCast>Hit_Confetti</soundCast>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>


</Defs>
