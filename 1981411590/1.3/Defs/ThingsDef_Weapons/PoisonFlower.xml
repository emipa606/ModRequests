<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="BaseBullet">
		<defName>DewFlower</defName>
		<label>Dew of Flower</label>
		<graphicData>
			<texPath>Things/Items/Flowerdew</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<flyOverhead>false</flyOverhead>
			<damageDef>Laugh</damageDef>
			<damageAmountBase>3</damageAmountBase>
			<stoppingPower>2.5</stoppingPower>
			<speed>40</speed>
		</projectile>
	</ThingDef>
	
	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>Clown_FlowerSquirt</defName>
		<label>Clown Flower</label>
		<description>Stop and smell the flower!</description>
		<graphicData>
			<texPath>Things/Items/FlowerSquirt</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Honk_Hit</soundInteract>
		<statBases>
			<WorkToMake>7000</WorkToMake>
			<Mass>3.0</Mass>
			<AccuracyTouch>.85</AccuracyTouch>
			<AccuracyShort>.96</AccuracyShort>
			<AccuracyMedium>.30</AccuracyMedium>
			<AccuracyLong>.15</AccuracyLong>
			<RangedWeapon_Cooldown>3.0</RangedWeapon_Cooldown>
		</statBases>
		<techLevel>Neolithic</techLevel>
		<recipeMaker>
			<recipeUsers>
				<li>TableMachining</li>
				<li>CraftingSpot</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<weaponTags>
			<li>ClownStuff</li>
		</weaponTags>
		<costList>
			<Synthread>20</Synthread>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>DewFlower</defaultProjectile>
				<warmupTime>1.1</warmupTime>
				<range>8</range>
				<soundCast>Honk_Hit</soundCast>
			</li>
		</verbs>

		<tools>
			<li>
				<label>flower</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>1</power>
				<cooldownTime>0.5</cooldownTime>
			</li>
		</tools>
	</ThingDef>
</Defs>