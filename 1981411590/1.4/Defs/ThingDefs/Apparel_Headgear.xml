<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- SS13Clown Mask -->
	<ThingDef ParentName="HatMakeableBase">
		<defName>Clown_SS13ClownMask</defName>
		<label>Clown Mask</label>
		<description>Don the mask; channel the funny.</description>
		<graphicData>
			<texPath>Things/Apparel/Display/SS13ClownMask</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<techLevel>Neolithic</techLevel>
		<recipeMaker>
			<recipeUsers>
				<li>TableMachining</li>
				<li>CraftingSpot</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<costList>
			<WoodLog>10</WoodLog>
			<Cloth>10</Cloth>
		</costList>
		<statBases>
			<WorkToMake>1000</WorkToMake>
			<MaxHitPoints>75</MaxHitPoints>
			<Mass>0.02</Mass>
			<StuffEffectMultiplierArmor>0.15</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.15</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.10</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.0</EquipDelay>
		</statBases>

		<equippedStatOffsets>
			<SocialImpact>-0.25</SocialImpact>
		</equippedStatOffsets>

		<apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Apparel/Headgear/SS13ClownMask</wornGraphicPath>
			<!--<hatRenderedFrontOfFace>true</hatRenderedFrontOfFace>-->
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<tags>
				<li>ClownMask</li>
				<li>ClownApparel</li>
			</tags>
		</apparel>
	</ThingDef>

