<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<!--==================================== RubberMallet ====================================-->

	<ThingDef ParentName="BaseMeleeWeapon_Blunt">
		<defName>Clown_RubberMallet</defName>
		<label>Rubber Mallet</label>
		<description>This 'rubber' mallet is made of tougher stuff.</description>
		<techLevel>Neolithic</techLevel>
		<graphicData>
			<texPath>Things/Items/RubberMallet</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_Rubber</soundInteract>
		<costList>
			<WoodLog>20</WoodLog>
		</costList>
		<stuffCategories>
			<li>Metallic</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
		<recipeMaker>
			<recipeUsers>
				<li>CraftingSpot</li>
				<li>TableMachining</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<weaponTags>
			<li>ClownStuff</li>
		</weaponTags>
		<statBases>
			<MaxHitPoints>120</MaxHitPoints>
			<WorkToMake>1200</WorkToMake>
			<Mass>2</Mass>
		</statBases>
		
		<equippedStatOffsets>
			<MeleeHitChance>.15</MeleeHitChance>
		</equippedStatOffsets>


		<tools>
			<li>
				<label>mallet</label>
				<capacities>
					<li>Clown_RubberSmash</li>
				</capacities>
				<power>15</power>
				<cooldownTime>3</cooldownTime>
			</li>
			<li>
				<label>handle</label>
				<capacities>
					<li>Clown_RubberHit</li>
				</capacities>
				<power>5</power>
				<cooldownTime>1.5</cooldownTime>
			</li>
		</tools>
	</ThingDef>
	
	<!-- Bonkers -->
	<DamageDef ParentName="BluntBase">
        <defName>Bonkers</defName>
        <label>Bonks</label>
        <workerClass>DamageWorker_AddInjury</workerClass>
        <additionalHediffs>
          <li>
            <hediff>Bonk</hediff>
            <severityPerDamageDealt>0.05</severityPerDamageDealt>
        <victimSeverityScaling>ToxicResistance</victimSeverityScaling>
        <inverseStatScaling>true</inverseStatScaling>
		</li>
        </additionalHediffs>
    </DamageDef>
    
    <HediffDef ParentName="DiseaseBase">
        <defName>Bonk</defName>
		<description>BONK</description>
        <label>Bonked</label>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>
                    <min>600</min>
                    <max>1000</max>
                </disappearsAfterTicks>
            </li>
        </comps>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <setMax>0.5</setMax>						
                    </li>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.15</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.15</offset>
					</li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

</Defs>