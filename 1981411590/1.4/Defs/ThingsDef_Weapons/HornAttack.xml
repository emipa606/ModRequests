<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- ================================= "BULLETS" ==================================== -->

	<ThingDef ParentName="BaseBullet">
		<defName>HonkSound</defName>
		<label>Clown Taunt</label>
		<graphicData>
		<texPath>Things/Items/HonkSound</texPath>
		<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Stun</damageDef>
			<damageAmountBase>10</damageAmountBase>
			<speed>100</speed>
		</projectile>
	</ThingDef>

  <!-- ================================= HORN ==================================== -->


	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>Clown_ClownHorn</defName>
		<label>Clown Horn</label>
		<description>Honky Tonky Honk.</description>
		<graphicData>
			<texPath>Things/Items/BikeHorn</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Honk_Interact</soundInteract>
		<recipeMaker>
			<recipeUsers>
				<li>TableMachining</li>
				<li>CraftingSpot</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>

		<weaponTags>
			<li>ClownStuff</li>
		</weaponTags>

		<statBases>
			<MarketValue>1500</MarketValue>
			<WorkToMake>2000</WorkToMake>
			<Mass>1.0</Mass>
			<AccuracyTouch>1.50</AccuracyTouch>
			<AccuracyShort>0.20</AccuracyShort>
			<AccuracyMedium>0.10</AccuracyMedium>
			<AccuracyLong>0.05</AccuracyLong>
			<RangedWeapon_Cooldown>1.00</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<Steel>20</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>HonkSound</defaultProjectile>
				<warmupTime>1.0</warmupTime>
				<range>25</range>
				<soundCast>Honk_Hit</soundCast>
			</li>
		</verbs>

		<tools>
			<li>
				<label>rubber</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>1</power>
			<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>metal bit</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>2</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>
  
	<!-- Gattling Horn -->
	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>Clown_GattlingHorn</defName>
		<label>Repeating Horn</label>
		<description>The power of ten clowns in one horn.</description>
		<graphicData>
			<texPath>Things/Items/GatHorn</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Honk_Interact</soundInteract>
		<statBases>
			<WorkToMake>10000</WorkToMake>
			<Mass>5</Mass>
			<AccuracyTouch>0.15</AccuracyTouch>
			<AccuracyShort>0.25</AccuracyShort>
			<AccuracyMedium>0.25</AccuracyMedium>
			<AccuracyLong>0.18</AccuracyLong>
			<RangedWeapon_Cooldown>2.3</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<Steel>150</Steel>
			<ComponentIndustrial>10</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<recipeUsers>
				<li>TableMachining</li>
				<li>CraftingSpot</li>
			</recipeUsers>
			<researchPrerequisite>ClownResearch</researchPrerequisite>
		</recipeMaker>
		<techLevel>Neolithic</techLevel>
		<weaponTags>
			<li>GunHeavy</li>
		</weaponTags>
		<equippedStatOffsets>
			<MoveSpeed>-0.15</MoveSpeed>
		</equippedStatOffsets>
		
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>HonkSound</defaultProjectile>
				<warmupTime>2.5</warmupTime>
				<range>30.9</range>
				<burstShotCount>30</burstShotCount>
				<ticksBetweenBurstShots>5</ticksBetweenBurstShots>
				<soundCast>Honk_Hit</soundCast>
				<muzzleFlashScale>4</muzzleFlashScale>
			</li>
		</verbs>
		
		<tools>
			<li>
				<label>barrels</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>11.7</power>
				<cooldownTime>2.6</cooldownTime>
			</li>
		</tools>
	</ThingDef>		

</Defs>