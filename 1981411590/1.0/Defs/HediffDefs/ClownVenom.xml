<Defs>
	<!-- Laughing Poison Hit -->
 <DamageDef ParentName="Flame">
    <defName>Laugh</defName>
    <label>Laughing</label>
    <additionalHediffs>
      <li>
        <hediff>LaughPoison</hediff>
        <severityPerDamageDealt>0.08</severityPerDamageDealt>
        <victimSeverityScaling>ToxicSensitivity</victimSeverityScaling>
      </li>
    </additionalHediffs>
    <deathMessage>{0} laughed their last laugh.</deathMessage>
  </DamageDef>

	<!-- Laughing Poison -->
  <HediffDef>
    <defName>LaughPoison</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(153, 51, 255)</defaultLabelColor>
    <label>Clown Venom</label>
    <lethalSeverity>1</lethalSeverity>
    <makesSickThought>true</makesSickThought>
    <scenarioCanAdd>true</scenarioCanAdd>
    <taleOnVisible>ToxicityRevealed</taleOnVisible>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>.5</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <label>Chuckling</label>
        <minSeverity>0.2</minSeverity>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Chackling</label>
        <minSeverity>0.40</minSeverity>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.30</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Laughing</label>
        <minSeverity>0.60</minSeverity>
        <vomitMtbDays>1</vomitMtbDays>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.50</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.50</offset>
          </li>
        </capMods>

      </li>
      <li>
        <label>Laughing Hysterically</label>
        <minSeverity>0.80</minSeverity>
        <vomitMtbDays>0.5</vomitMtbDays>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.90</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.90</offset>
          </li>
        </capMods>
        <hediffGivers>
          <li Class="HediffGiver_Random">
            <hediff>HeartAttack</hediff>
            <mtbDays>5</mtbDays>
            <partsToAffect>
              <li>Heart</li>
            </partsToAffect>
          </li>
        </hediffGivers>
      </li>
    </stages>
  </HediffDef>
  
  <ThoughtDef>
    <defName>Laughing_Poison</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>LaughPoison</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <stages>
      <li>
        <label>happy for no reason</label>
        <description>I just can't help but smile.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
      <li>
        <label>laughing hurts</label>
        <description>It hurts to laugh... help!</description>
        <baseMoodEffect>-5</baseMoodEffect>
      </li>
      <li>
        <label>why so serious</label>
        <description>Life is a comedy!</description>
        <baseMoodEffect>15</baseMoodEffect>
      </li>
      <li>
        <label>serious (hidden)</label>
        <visible>false</visible>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
