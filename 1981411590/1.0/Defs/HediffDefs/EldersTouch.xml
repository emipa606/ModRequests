<Defs>
	<!-- Elders Touch -->
	 
	 <DamageDef ParentName="Bite">
		<defName>TouchElder</defName>
		<label>ElderTouch</label>
		<additionalHediffs>
		  <li>
			<hediff>EldersTouch</hediff>
			<severityPerDamageDealt>0.08</severityPerDamageDealt>
			<victimSeverityScaling>ToxicSensitivity</victimSeverityScaling>
		  </li>
		</additionalHediffs>
		<deathMessage>{0} has been enlightened.</deathMessage>
	  </DamageDef>		
	
	
	<HediffDef>
		<defName>EldersTouch</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(153, 51, 255)</defaultLabelColor>
		<label>Elders Touch</label>
		<lethalSeverity>3</lethalSeverity>
		<makesSickThought>true</makesSickThought>
		<scenarioCanAdd>true</scenarioCanAdd>
		<taleOnVisible>ToxicityRevealed</taleOnVisible>
		<comps>
			<li Class="HediffCompProperties_Effecter">
				<stateEffecter>Berserk</stateEffecter>
				<severityIndices>
					<min>3</min>
					<max>5</max>
				</severityIndices>
			</li>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>1.0</severityPerDay>
			</li>
		</comps>
		<stages>
			<li>
				<label>headache</label>
				<painFactor>0.8</painFactor>
				<socialFightChanceFactor>1.5</socialFightChanceFactor>
				<capMods>
					<li>
					<capacity>Manipulation</capacity>
					<offset>-0.05</offset>
					</li>
				</capMods>
			</li>
			<li>
				<minSeverity>0.25</minSeverity>
				<label>throbbing headache</label>
				<painFactor>0.7</painFactor>
				<socialFightChanceFactor>4.5</socialFightChanceFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.10</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.05</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
			</li>
			<li>
				<minSeverity>0.4</minSeverity>
				<label>pulsing headache</label>
				<painFactor>0.4</painFactor>
				<socialFightChanceFactor>6.0</socialFightChanceFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.35</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.10</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.20</offset>
					</li>
				</capMods>
				<hediffGivers>
					<li Class="HediffGiver_Random">
						<hediff>ChemicalDamageModerate</hediff>
						<mtbDays>0.8</mtbDays>
						<partsToAffect>
							<li>Brain</li>
						</partsToAffect>
					</li>
				</hediffGivers>
				<mentalStateGivers>
					<li>
						<mentalState>Berserk</mentalState>
						<mtbDays>0.5</mtbDays>
					</li>
				</mentalStateGivers>
			</li>
			<li>
				<minSeverity>0.7</minSeverity>
				<label>exploding headache</label>
				<painFactor>0.2</painFactor>
				<socialFightChanceFactor>8.0</socialFightChanceFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.50</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.10</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.30</offset>
					</li>
				</capMods>
				<hediffGivers>
					<li Class="HediffGiver_Random">
						<hediff>ChemicalDamageModerate</hediff>
						<mtbDays>0.5</mtbDays>
						<partsToAffect>
							<li>Brain</li>
						</partsToAffect>
					</li>
					<li Class="HediffGiver_Random">
						<hediff>Dementia</hediff>
						<mtbDays>2</mtbDays>
						<partsToAffect>
							<li>Brain</li>
						</partsToAffect>
					</li>
				</hediffGivers>
				<mentalStateGivers>
					<li>
						<mentalState>Berserk</mentalState>
						<mtbDays>0.5</mtbDays>
					</li>
				</mentalStateGivers>
			</li>
			<li>
				<minSeverity>0.9</minSeverity>
				<label>Blackout</label>
				<painFactor>0.1</painFactor>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.1</setMax>
					</li>
				</capMods>
				<hediffGivers>
					<li Class="HediffGiver_Random">
						<hediff>ChemicalDamageSevere</hediff>
						<mtbDays>0.2</mtbDays>
						<partsToAffect>
							<li>Brain</li>
						</partsToAffect>
					</li>
					<li Class="HediffGiver_Random">
						<hediff>Dementia</hediff>
						<mtbDays>1</mtbDays>
						<partsToAffect>
							<li>Brain</li>
						</partsToAffect>
					</li>
				</hediffGivers>
			</li>
		</stages>
	</HediffDef>
	
	<ThoughtDef>
		<defName>Enlightenment</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>EldersTouch</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>hearing whispers</label>
				<description>Who said that?</description>
				<baseMoodEffect>-3</baseMoodEffect>
			</li>
			<li>
				<label>hearing voices</label>
				<description>Are you hearing this?</description>
				<baseMoodEffect>-5</baseMoodEffect>
			</li>
			<li>
				<label>seeing visions</label>
				<description>I don't believe what I ... see?</description>
				<baseMoodEffect>-10</baseMoodEffect>
			</li>
			<li>
				<label>gained wisdom</label>
				<description>I understand now.</description>
				<baseMoodEffect>15</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>
</Defs>