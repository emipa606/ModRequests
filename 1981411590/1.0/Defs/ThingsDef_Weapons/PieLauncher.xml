<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- Pies -->
  <ThingDef ParentName="BaseBullet">
    <defName>Pie_Bullet</defName>
    <label>amore</label>
      <graphicData>
      <texPath>Things/Items/PieAmmo</texPath>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
      <speed>20</speed>
      <damageDef>Flame</damageDef>
      <explosionRadius>2.9</explosionRadius>
      <postExplosionSpawnThingDef>Filth_Tar</postExplosionSpawnThingDef>
      <postExplosionSpawnChance>1.0</postExplosionSpawnChance>
      <postExplosionSpawnThingCount>5</postExplosionSpawnThingCount>
      <ai_IsIncendiary>true</ai_IsIncendiary>
      </projectile>
  </ThingDef>
  
  <!-- Pie Launcher -->
  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>Clown_PieCannon</defName>
    <label>Rainbow Pie Cannon</label>
    <description>This colorful tube of questionable construct will deliver a sweet treat, which is to die for.</description>
    <graphicData>
      <texPath>Things/Items/PieShooter</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_PieCannon</soundInteract>
    <generateCommonality>0.3</generateCommonality>
    <statBases>
      <WorkToMake>10000</WorkToMake>
      <Mass>4.5</Mass>
      <RangedWeapon_Cooldown>3.5</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>50</Steel>
      <Meat_Human>100</Meat_Human>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <techLevel>Neolithic</techLevel>
    <recipeMaker>
        <recipeUsers>
            <li>TableMachining</li>
            <li>CraftingSpot</li>
        </recipeUsers>
        <researchPrerequisite>ClownResearch</researchPrerequisite>
    </recipeMaker>
      <weaponTags>
        <li>ClownStuff</li>
      </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Pie_Bullet</defaultProjectile>
        <warmupTime>3.0</warmupTime>
        <range>20</range>
        <forcedMissRadius>1.9</forcedMissRadius>
        <burstShotCount>1</burstShotCount>
        <soundCast>Pie_Fling</soundCast>
        <muzzleFlashScale>5</muzzleFlashScale>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

</Defs>