		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_ElectromechanicalHeart</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Heart</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_ElectromechanicalHeart</addsHediff>
