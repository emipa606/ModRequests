	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_CyberneticHeart</defName>
		<label>Cybernetic heart</label>
		<description>A complex implant with many modes of operation, automatically adjusting the pulse rate to the desire of the owner.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_CyberneticHeart</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.5</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>2</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<WorkSpeedGlobal>0.2</WorkSpeedGlobal>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<hungerRateFactor>0.8</hungerRateFactor>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<RestRateMultiplier>0.2</RestRateMultiplier>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.075</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.4</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.5</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_CyberneticHeart</parent>
				<programmable>true</programmable>
				<abilityDefs>
					<li>DimonSever000_HeartImpulse</li>
				</abilityDefs>
			</li>
		</comps>
	</HediffDef>
