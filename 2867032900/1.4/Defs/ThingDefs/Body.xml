	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_CPU</defName>
		<label>CPU</label>
		<description>The central processing unit, which manages and distributes energy in the system. Required to access the settings menu.</description>
		<hediffClass>ProsthesesCore.CPU</hediffClass>
		<spawnThingOnRemoved>DimonSever000_CPU</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>true</worksWithoutPower>
				<energyConsume>0.020</energyConsume>
				<energyAccumulate>5</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1</partHealthMult>
				<showInCPU>true</showInCPU>
				<disailable>false</disailable>
				<disabledStage>
					<label>disabled</label>
				</disabledStage>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisBlueBase">
