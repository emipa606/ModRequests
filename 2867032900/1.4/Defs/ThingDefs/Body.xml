	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_BasicMechanites</defName>
		<label>Basic mechanites</label>
		<description>A huge number of small robots resembling a swarm of insects that live and maintain the health of the body. They have several modes of operation.</description>
		<hediffClass>ProsthesesCore.CustomImplant</hediffClass>
		<spawnThingOnRemoved>DimonSever000_BasicMechanites</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>3</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<capMods>
					<li>
						<capacity>Hearing</capacity>
						<offset>0.10</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.10</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<offset>0.10</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>0.10</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<capMods>
					<li>
						<capacity>BloodFiltration</capacity>
						<offset>0.10</offset>
					</li>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.10</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>M3</label>
				<minSeverity>3</minSeverity>
				<capMods>
					<li>
						<capacity>Talking</capacity>
						<offset>0.10</offset>
					</li>
					<li>
						<capacity>Breathing</capacity>
						<offset>0.10</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.040</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.0</partHealthMult>
				<disabledStage>
					<label>disabled</label>
				</disabledStage>
				<parent>DimonSever000_BasicMechanites</parent>
				<programmable>true</programmable>
			</li>
		</comps>
		<tags>
			<li>DimonSever000_Mechanites</li>
		</tags>
	</HediffDef>
