<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_ProgrammableRibcage</defName>
		<label>Programmable ribcage</label>
		<description>Synthetic ribcage with a set of operating modes.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_ProgrammableRibcage</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>2</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<WorkSpeedGlobal>0.1</WorkSpeedGlobal>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statFactors>
					<MoveSpeed>1.1</MoveSpeed>
				</statFactors>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<ArmorRating_Sharp>0.15</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.020</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.3</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.0</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_ProgrammableRibcage</parent>
				<programmable>true</programmable>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisBlueBase">
		<defName>DimonSever000_ProgrammableRibcage</defName>
		<label>Programmable ribcage</label>
		<description>Synthetic ribcage with a set of operating modes.</description>
		<graphicData>
			<texPath>Things/Items/BlueRibcage</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Plasteel>20</Plasteel>
			<ComponentSpacer>2</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_ProgrammableEquipment</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_ProgrammableRibcage</defName>
		<label>Install programmable ribcage</label>
		<description>Install programmable ribcage.</description>
		<jobString>Installing programmable ribcage.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_ProgrammableRibcage</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_ProgrammableRibcage</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Ribcage</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_ProgrammableRibcage</addsHediff>
	</RecipeDef>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_CyberneticRibcage</defName>
		<label>Cybernetic ribcage</label>
		<description>A complex implant with ribcage function, working at the maximum of biomechanics.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_CyberneticRibcage</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>2</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<WorkSpeedGlobal>0.2</WorkSpeedGlobal>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statFactors>
					<MoveSpeed>1.2</MoveSpeed>
				</statFactors>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.040</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.4</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.0</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_CyberneticRibcage</parent>
				<programmable>true</programmable>
				<abilityDefs>
					<li>DimonSever000_Teleport</li>
				</abilityDefs>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisPurpleBase">
		<defName>DimonSever000_CyberneticRibcage</defName>
		<label>Cybernetic ribcage</label>
		<description>A complex implant with ribcage function, working at the maximum of biomechanics.</description>
		<graphicData>
			<texPath>Things/Items/PurpleRibcage</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Plasteel>30</Plasteel>
			<ComponentSpacer>4</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_CyberneticEquipment</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_CyberneticRibcage</defName>
		<label>Install cybernetic ribcage</label>
		<description>Install cybernetic ribcage.</description>
		<jobString>Installing cybernetic ribcage.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_CyberneticRibcage</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_CyberneticRibcage</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Ribcage</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_CyberneticRibcage</addsHediff>
	</RecipeDef>
	<!---->
</Defs>