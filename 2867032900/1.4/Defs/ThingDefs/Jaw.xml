<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_SpeechImplant</defName>
		<label>Speech implant</label>
		<description>A device that makes it possible to emulate human speech with different tonality, which is useful in social interactions.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_SpeechImplant</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.3</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>1</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<SocialImpact>0.3</SocialImpact>
					<TradePriceImprovement>0.3</TradePriceImprovement>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statOffsets>
					<TameAnimalChance>0.3</TameAnimalChance>
					<TrainAnimalChance>0.3</TrainAnimalChance>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.015</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.3</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.3</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_SpeechImplant</parent>
				<programmable>true</programmable>
				<abilityDefs>
					<li>DimonSever000_SoundWave</li>
				</abilityDefs>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisBlueBase">
		<defName>DimonSever000_SpeechImplant</defName>
		<label>Speech implant</label>
		<description>A device that makes it possible to emulate human speech with different tonality, which is useful in social interactions.</description>
		<graphicData>
			<texPath>Things/Items/BlueJaw</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Synthread>25</Synthread>
			<ComponentSpacer>3</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_SpeechModification</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_SpeechImplant</defName>
		<label>Install speech implant</label>
		<description>Install speech implant.</description>
		<jobString>Installing speech implant.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_SpeechImplant</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_SpeechImplant</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Jaw</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_SpeechImplant</addsHediff>
	</RecipeDef>
	<!---->
</Defs>