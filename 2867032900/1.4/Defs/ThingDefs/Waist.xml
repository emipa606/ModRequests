<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_SolarGenerator</defName>
		<label>Solar generator</label>
		<description>Mobile small complex of solar panels, which are located on the waist. Suitable for generating small amounts of power. Works at any time of the day.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_SolarGenerator</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>true</worksWithoutPower>
				<energyConsume>-0.100</energyConsume>
				<energyAccumulate>250</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_SolarGenerator</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisYellowBase">
		<defName>DimonSever000_SolarGenerator</defName>
		<label>Solar generator</label>
		<description>Mobile small complex of solar panels, which are located on the waist. Suitable for generating small amounts of power. Works at any time of the day.</description>
		<graphicData>
			<texPath>Things/Items/YellowGenerator</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>10</Mass>
		</statBases>
		<costList>
			<Steel>75</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_BasicEquipment</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_SolarGenerator</defName>
		<label>Install solar generator</label>
		<description>Install solar generator.</description>
		<jobString>Installing solar generator.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_SolarGenerator</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_SolarGenerator</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Waist</li>
			<li>Heart</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_SolarGenerator</addsHediff>
	</RecipeDef>
