<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!---->
	<AbilityDef>
		<defName>DimonSever000_EnergySpear</defName>
		<label>Energy spear</label>
		<description>Throws a beam of energy from the hand in the form of a spear to inflict serious damage on the target.</description>
		<abilityClass>ProsthesesCore.ProsthesisAbility</abilityClass>
		<gizmoClass>ProsthesesCore.Command_ProsthesisAbility</gizmoClass>
		<iconPath>UI/EnergySpear</iconPath>
		<stunTargetWhileCasting>false</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<warmupSound>ImmunityDrive_Resolve</warmupSound>
		<statBases>
			<DimonSever000_EnergyCost>150</DimonSever000_EnergyCost>
		</statBases>
		<comps>
			<li Class="CompProperties_AbilityFleckOnTarget">
				<fleckDef>PsycastPsychicEffect</fleckDef>
			</li>
		</comps>
		<jobDef>UseVerbOnThingStatic</jobDef>
		<verbProperties>
			<verbClass>ProsthesesCore.Verb_Ability_LaunchProjectileStatic</verbClass>
			<defaultProjectile>Bullet_ChargeLance</defaultProjectile>
			<warmupTime>1.5</warmupTime>
			<range>20</range>
			<drawAimPie>true</drawAimPie>
			<requireLineOfSight>true</requireLineOfSight>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetAnimals>true</canTargetAnimals>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	<!---->
	<AbilityDef>
		<defName>DimonSever000_LaserBeam</defName>
		<label>Laser beam</label>
		<description>A powerful and thin laser capable of melting the enemy through and through. Requires a large supply of energy.</description>
		<abilityClass>ProsthesesCore.ProsthesisAbility</abilityClass>
		<gizmoClass>ProsthesesCore.Command_ProsthesisAbility</gizmoClass>
		<iconPath>UI/LaserBeam</iconPath>
		<stunTargetWhileCasting>false</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<warmupSound>ImmunityDrive_Resolve</warmupSound>
		<statBases>
			<DimonSever000_EnergyCost>200</DimonSever000_EnergyCost>
		</statBases>
		<comps>
			<li Class="ProsthesesCore.CompProperties_AbilityFleckConnecting">
				<fleckDef>DimonSever000_LaserBeam</fleckDef>
			</li>
		</comps>
		<jobDef>UseVerbOnThingStatic</jobDef>
		<verbProperties>
			<verbClass>ProsthesesCore.Verb_Ability_LaunchProjectileStatic</verbClass>
			<defaultProjectile>DimonSever000_LaserBeam</defaultProjectile>
			<warmupTime>1.5</warmupTime>
			<range>15</range>
			<drawAimPie>true</drawAimPie>
			<requireLineOfSight>true</requireLineOfSight>
			<defaultCooldownTime>1</defaultCooldownTime>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetAnimals>true</canTargetAnimals>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	<FleckDef ParentName="FleckGlowDistortBackground">
		<defName>DimonSever000_LaserBeam</defName>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<fadeInTime>0.1</fadeInTime>
		<fadeOutTime>0.3</fadeOutTime>
		<solidTime>0.0</solidTime>
		<graphicData>
			<texPath>Things/Mote/LaserBeam</texPath>
			<shaderParameters>
				<_distortionIntensity>0.15</_distortionIntensity>
				<_DistortionTex>/Things/Mote/LaserBeamMask</_DistortionTex>
			</shaderParameters>
		</graphicData>
	</FleckDef>
	<ThingDef ParentName="BaseBullet">
		<defName>DimonSever000_LaserBeam</defName>
		<label>Laser beam</label>
		<graphicData>
			<texPath>Things/NullTexture</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
			<drawSize>1</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Flame</damageDef>
			<damageAmountBase>35</damageAmountBase>
			<stoppingPower>1.5</stoppingPower>
			<speed>10000</speed>
			<armorPenetrationBase>0.5</armorPenetrationBase>
		</projectile>
	</ThingDef>
	<!---->
	<AbilityDef>
		<defName>DimonSever000_ReactiveJump</defName>
		<label>Reactive jump</label>
		<description>A fast jump performed with the release of energy.</description>
		<abilityClass>ProsthesesCore.ProsthesisAbility</abilityClass>
		<gizmoClass>ProsthesesCore.Command_ProsthesisAbility</gizmoClass>
		<iconPath>UI/ReactiveJump</iconPath>
		<stunTargetWhileCasting>false</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<warmupSound>ImmunityDrive_Resolve</warmupSound>
		<statBases>
			<DimonSever000_EnergyCost>250</DimonSever000_EnergyCost>
		</statBases>
		<comps>
			<li Class="ProsthesesCore.CompProperties_AbilityFleckConnecting">
			</li>
		</comps>
		<jobDef>UseVerbOnThingStatic</jobDef>
		<verbProperties>
			<verbClass>ProsthesesCore.Verb_Jump</verbClass>
			<violent>false</violent>
			<hasStandardCommand>true</hasStandardCommand>
			<onlyManualCast>True</onlyManualCast>
			<forceNormalTimeSpeed>false</forceNormalTimeSpeed>
			<warmupTime>0.5</warmupTime>
			<requireLineOfSight>true</requireLineOfSight>
			<range>20</range>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetPawns>false</canTargetPawns>
				<canTargetBuildings>false</canTargetBuildings>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	<!---->
	<AbilityDef>
		<defName>DimonSever000_HeartImpulse</defName>
		<label>Heart impulse</label>
		<description>The release of a large amount of energy to hit the area.</description>
		<abilityClass>ProsthesesCore.ProsthesisAbility</abilityClass>
		<gizmoClass>ProsthesesCore.Command_ProsthesisAbility</gizmoClass>
		<iconPath>UI/HeartImpulse</iconPath>
		<stunTargetWhileCasting>false</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<warmupSound>ImmunityDrive_Resolve</warmupSound>
		<statBases>
			<DimonSever000_EnergyCost>500</DimonSever000_EnergyCost>
		</statBases>
		<comps>
			<li Class="CompProperties_AbilityFleckOnTarget">
				<fleckDef>PsycastPsychicEffect</fleckDef>
			</li>
		</comps>
		<jobDef>UseVerbOnThingStatic</jobDef>
		<verbProperties>
			<verbClass>ProsthesesCore.Verb_Ability_LaunchProjectileStatic</verbClass>
			<defaultProjectile>DimonSever000_HeartImpulse</defaultProjectile>
			<warmupTime>1.5</warmupTime>
			<range>15</range>
			<drawAimPie>true</drawAimPie>
			<requireLineOfSight>true</requireLineOfSight>
			<defaultCooldownTime>1</defaultCooldownTime>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetAnimals>true</canTargetAnimals>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	<ThingDef ParentName="BaseBullet">
		<defName>DimonSever000_HeartImpulse</defName>
		<label>heart impulse</label>
		<graphicData>
			<texPath>Things/NullTexture</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>ProsthesesCore.Projectile_HeartImpulse</thingClass>
		<projectile>
			<speed>10000</speed>
			<damageDef>Flame</damageDef>
			<explosionRadius>3</explosionRadius>
			<ai_IsIncendiary>true</ai_IsIncendiary>
			<arcHeightFactor>0.2</arcHeightFactor>
			<shadowSize>0.6</shadowSize>
		</projectile>
	</ThingDef>
	<!---->
	<AbilityDef>
		<defName>DimonSever000_SoundWave</defName>
		<label>Sound wave</label>
		<description>A terrifying sound wave that deafens others, plunging them into panic.</description>
		<abilityClass>ProsthesesCore.ProsthesisAbility</abilityClass>
		<gizmoClass>ProsthesesCore.Command_ProsthesisAbility</gizmoClass>
		<iconPath>UI/SoundWave</iconPath>
		<targetRequired>False</targetRequired>
		<canUseAoeToGetTargets>True</canUseAoeToGetTargets>
		<showCastingProgressBar>True</showCastingProgressBar>
		<stunTargetWhileCasting>false</stunTargetWhileCasting>
		<warmupMote>Mote_WarmupNeuroquake</warmupMote>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<warmupSound>ImmunityDrive_Resolve</warmupSound>
		<statBases>
			<DimonSever000_EnergyCost>800</DimonSever000_EnergyCost>
			<Ability_Duration>15</Ability_Duration>
		</statBases>
		<comps>
			<li Class="CompProperties_AbilityFleckOnTarget">
				<fleckDef>PsychicApplyNeuroquake</fleckDef>
				<sound>Psycast_Neuroquake_Effect</sound>
			  </li>
		</comps>
		<jobDef>CastAbilityOnThingUninterruptible</jobDef>
		<verbProperties>
			<verbClass>ProsthesesCore.Verb_SoundWave</verbClass>
			<warmupTime>2</warmupTime>
			<range>8</range>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
			<defaultCooldownTime>2</defaultCooldownTime>
			<!--<targetable>false</targetable>-->
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	<!---->
	<AbilityDef>
		<defName>DimonSever000_Teleport</defName>
		<label>Teleport</label>
		<description>Mobile short-range teleporter for instant travel. Installed in the intercostal space.</description>
		<abilityClass>ProsthesesCore.ProsthesisAbility</abilityClass>
		<gizmoClass>ProsthesesCore.Command_ProsthesisAbility</gizmoClass>
		<iconPath>UI/Teleport</iconPath>
		<stunTargetWhileCasting>false</stunTargetWhileCasting>
		<showPsycastEffects>False</showPsycastEffects>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<warmupSound>ImmunityDrive_Resolve</warmupSound>
		<statBases>
			<DimonSever000_EnergyCost>200</DimonSever000_EnergyCost>
		</statBases>
		<comps>
			<li Class="ProsthesesCore.CompProperties_AbilityFleckConnecting">
			</li>
		</comps>
		<jobDef>UseVerbOnThingStatic</jobDef>
		<verbProperties>
			<verbClass>ProsthesesCore.Verb_Teleport</verbClass>
			<warmupTime>0.3</warmupTime>
			<range>10</range>
			<drawAimPie>true</drawAimPie>
			<requireLineOfSight>true</requireLineOfSight>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetAnimals>true</canTargetAnimals>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	<!---->
</Defs>