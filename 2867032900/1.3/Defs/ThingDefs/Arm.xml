<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_ElectromechanicalArm</defName>
		<label>Electromechanical arm</label>
		<description>A fragile prosthetic arm, covered with sensors and various devices for fine control.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_ElectromechanicalArm</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
					<li>
						<label>Electromechanical arm</label>
						<capacities>
							<li>Blunt</li>
						</capacities>
						<power>10.0</power>
						<cooldownTime>2</cooldownTime>
					</li>
				</tools>
			</li>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.015</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_ElectromechanicalArm</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisYellowBase">
		<defName>DimonSever000_ElectromechanicalArm</defName>
		<label>Electromechanical arm</label>
		<description>A fragile prosthetic arm, covered with sensors and various devices for fine control.</description>
		<graphicData>
			<texPath>Things/Items/YellowArm</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>5</Mass>
		</statBases>
		<costList>
			<Steel>50</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_AdvancedProsthetics</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_ElectromechanicalArm</defName>
		<label>Install electromechanical arm</label>
		<description>Install electromechanical arm.</description>
		<jobString>Installing electromechanical arm.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_ElectromechanicalArm</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_ElectromechanicalArm</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Shoulder</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_ElectromechanicalArm</addsHediff>
	</RecipeDef>
