			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<MeleeHitChance>4</MeleeHitChance>
					<MeleeDodgeChance>4</MeleeDodgeChance>
					<ShootingAccuracyPawn>4</ShootingAccuracyPawn>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
					<li>
						<label>Cybernetic arm</label>
						<capacities>
							<li>Blunt</li>
						</capacities>
						<power>12.0</power>
						<cooldownTime>2</cooldownTime>
					</li>
				</tools>
			</li>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.060</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.4</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.5</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_CyberneticArm</parent>
				<programmable>true</programmable>
				<abilityDefs>
					<li>DimonSever000_EnergySpear</li>
				</abilityDefs>
			</li>
		</comps>
	</HediffDef>
