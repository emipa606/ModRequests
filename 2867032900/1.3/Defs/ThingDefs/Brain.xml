<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_Neuromodulator</defName>
		<label>Neuromodulator</label>
		<description>A personality modulator capable of slow development up to a certain threshold of effectiveness.</description>
		<hediffClass>ProsthesesCore.AIBrainProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_Neuromodulator</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.100</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.1</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_Neuromodulator</parent>
			</li>
			<li Class="ProsthesesCore.HediffCompProperties_BrainProsthesis">
				<curvePoints>
					<points>
						<li>0, 0.8</li>
						<li>1, 1.1</li>
					</points>
				</curvePoints>
				<maxPoints>1</maxPoints>
				<pointsPerSecond>0.0001</pointsPerSecond>
				<extraLabel>Learning</extraLabel>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisYellowBase">
		<defName>DimonSever000_Neuromodulator</defName>
		<label>Neuromodulator</label>
		<description>A personality modulator capable of slow development up to a certain threshold of effectiveness.</description>
		<graphicData>
			<texPath>Things/Items/BlueBrain</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>5</Mass>
		</statBases>
		<costList>
			<Synthread>50</Synthread>
			<ComponentSpacer>4</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_NeuralModulation</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_Neuromodulator</defName>
		<label>Install neuromodulator</label>
		<description>Install neuromodulator.</description>
		<jobString>Installing neuromodulator.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_Neuromodulator</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_Neuromodulator</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Brain</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_Neuromodulator</addsHediff>
	</RecipeDef>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_NeutralNetwork</defName>
		<label>Neutral network</label>
		<description>A simple and slow neural network that learns to perform standard actions while simulating a person. Can develop good potential with long-term training.</description>
		<hediffClass>ProsthesesCore.AIBrainProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_NeutralNetwork</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.25</partEfficiency>
		</addedPartProps>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<WorkSpeedGlobal>0.1</WorkSpeedGlobal>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statOffsets>
					<MedicalTendSpeed>0.1</MedicalTendSpeed>
					<MedicalTendQuality>0.1</MedicalTendQuality>
				</statOffsets>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<MeleeHitChance>0.1</MeleeHitChance>
					<MeleeDodgeChance>0.1</MeleeDodgeChance>
					<ShootingAccuracyPawn>0.1</ShootingAccuracyPawn>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.180</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.25</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_NeutralNetwork</parent>
				<programmable>true</programmable>
			</li>
			<li Class="ProsthesesCore.HediffCompProperties_BrainProsthesis">
				<curvePoints>
					<points>
						<li>0, 0.5</li>
						<li>1, 1.25</li>
					</points>
				</curvePoints>
				<maxPoints>1</maxPoints>
				<pointsPerSecond>0.0000715</pointsPerSecond>
				<extraLabel>Learning</extraLabel>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="DimonSever000_ProsthesisYellowBase">
		<defName>DimonSever000_NeutralNetwork</defName>
		<label>Neutral network</label>
