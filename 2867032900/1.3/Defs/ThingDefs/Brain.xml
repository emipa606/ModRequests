		</statBases>
		<costList>
			<Hyperweave>50</Hyperweave>
			<ComponentSpacer>6</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>DimonSever000_NeuralModulation</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>DimonSever000_NeutralNetwork</defName>
		<label>Install neutral network</label>
		<description>Install neutral network.</description>
		<jobString>Installing neutral network.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>DimonSever000_NeutralNetwork</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>DimonSever000_NeutralNetwork</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Brain</li>
		</appliedOnFixedBodyParts>
		<addsHediff>DimonSever000_NeutralNetwork</addsHediff>
	</RecipeDef>
