	<HediffDef ParentName="AddedBodyPartBase">
		<defName>DimonSever000_ElectromechanicalLiver</defName>
		<label>Electromechanical liver</label>
		<description>An electronic filter that ensures the functions of the liver in the body.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>DimonSever000_ElectromechanicalLiver</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.010</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>DimonSever000_ElectromechanicalLiver</parent>
			</li>
		</comps>
	</HediffDef>
