	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>CyberneticLung</defName>
		<label>Cybernetic lung</label>
		<description>The most complex device that provides the functions of the lung in the body with several modes of operation.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>CyberneticLung</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.5</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>2</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<ToxicEnvironmentResistance>0.2</ToxicEnvironmentResistance>
					<ToxicResistance>0.2</ToxicResistance>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statOffsets>
					<ComfyTemperatureMin>-10</ComfyTemperatureMin>
				</statOffsets>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<ComfyTemperatureMax>10</ComfyTemperatureMax>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.040</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.4</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.5</partEfficiencyOffset>
				</disabledStage>
				<parent>CyberneticLung</parent>
				<programmable>true</programmable>
			</li>
		</comps>
	</HediffDef>
