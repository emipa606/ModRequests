<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>ElectromechanicalLung</defName>
		<label>Electromechanical lung</label>
		<description>A gas filter that performs the function of a lung. Saturates the blood with oxygen, although it has a fragile device.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>ElectromechanicalLung</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.010</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>ElectromechanicalLung</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisYellowBase">
		<defName>ElectromechanicalLung</defName>
		<label>Electromechanical lung</label>
		<description>A gas filter that performs the function of a lung. Saturates the blood with oxygen, although it has a fragile device.</description>
		<graphicData>
			<texPath>Things/Items/YellowLung</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Steel>30</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>OrgansReplacement</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>ElectromechanicalLung</defName>
		<label>Install electromechanical lung</label>
		<description>Install electromechanical lung.</description>
		<jobString>Installing electromechanical lung.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ElectromechanicalLung</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ElectromechanicalLung</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Lung</li>
		</appliedOnFixedBodyParts>
		<addsHediff>ElectromechanicalLung</addsHediff>
	</RecipeDef>
