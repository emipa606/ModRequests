<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>ProgrammableSpine</defName>
		<label>Programmable spine</label>
		<description>Elastic and strong vertebrae interconnected.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>ProgrammableSpine</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.35</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>2</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<WorkSpeedGlobal>0.1</WorkSpeedGlobal>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statFactors>
					<MoveSpeed>1.1</MoveSpeed>
				</statFactors>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<CarryingCapacity>40</CarryingCapacity>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.045</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.3</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.35</partEfficiencyOffset>
				</disabledStage>
				<parent>ProgrammableSpine</parent>
				<programmable>true</programmable>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisBlueBase">
		<defName>ProgrammableSpine</defName>
		<label>Programmable spine</label>
		<description>Elastic and strong vertebrae interconnected.</description>
		<graphicData>
			<texPath>Things/Items/BlueSpine</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Plasteel>25</Plasteel>
			<ComponentSpacer>5</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>NeuralModulation</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>ProgrammableSpine</defName>
		<label>Install programmable spine</label>
		<description>Install programmable spine.</description>
		<jobString>Installing programmable spine.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ProgrammableSpine</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ProgrammableSpine</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Spine</li>
		</appliedOnFixedBodyParts>
		<addsHediff>ProgrammableSpine</addsHediff>
	</RecipeDef>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>CyberneticSpine</defName>
		<label>Cybernetic spine</label>
		<description>A perfect implant that replaces the spine, capable of withstanding heavy loads.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>CyberneticSpine</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.5</partEfficiency>
		</addedPartProps>
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>2</maxSeverity>
		<stages>
			<li>
				<label>M0</label>
				<statOffsets>
					<WorkSpeedGlobal>0.2</WorkSpeedGlobal>
				</statOffsets>
			</li>
			<li>
				<label>M1</label>
				<minSeverity>1</minSeverity>
				<statFactors>
					<MoveSpeed>1.2</MoveSpeed>
				</statFactors>
			</li>
			<li>
				<label>M2</label>
				<minSeverity>2</minSeverity>
				<statOffsets>
					<CarryingCapacity>100</CarryingCapacity>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.060</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>1.4</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1.5</partEfficiencyOffset>
				</disabledStage>
				<parent>CyberneticSpine</parent>
				<programmable>true</programmable>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisPurpleBase">
		<defName>CyberneticSpine</defName>
		<label>Cybernetic spine</label>
		<description>A perfect implant that replaces the spine, capable of withstanding heavy loads.</description>
		<graphicData>
			<texPath>Things/Items/PurpleSpine</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Plasteel>40</Plasteel>
			<ComponentSpacer>6</ComponentSpacer>
		</costList>
		<recipeMaker>
			<researchPrerequisite>AdvancedNeuralModulation</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>CyberneticSpine</defName>
		<label>Install cybernetic spine</label>
		<description>Install cybernetic spine.</description>
		<jobString>Installing cybernetic spine.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>CyberneticSpine</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>CyberneticSpine</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Spine</li>
		</appliedOnFixedBodyParts>
		<addsHediff>CyberneticSpine</addsHediff>
	</RecipeDef>
	<!---->
</Defs>