<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>ElectromechanicalLeg</defName>
		<label>Electromechanical leg</label>
		<description>A fragile prosthetic leg, covered with sensors and various devices for fine control.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>ElectromechanicalLeg</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.010</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>ElectromechanicalLeg</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisYellowBase">
		<defName>ElectromechanicalLeg</defName>
		<label>Electromechanical leg</label>
		<description>A fragile prosthetic leg, covered with sensors and various devices for fine control.</description>
		<graphicData>
			<texPath>Things/Items/YellowLeg</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>8</Mass>
		</statBases>
		<costList>
			<Steel>50</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>AdvancedProsthetics</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>ElectromechanicalLeg</defName>
		<label>Install electromechanical leg</label>
		<description>Install electromechanical leg.</description>
		<jobString>Installing electromechanical leg.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ElectromechanicalLeg</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ElectromechanicalLeg</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Leg</li>
		</appliedOnFixedBodyParts>
		<addsHediff>ElectromechanicalLeg</addsHediff>
	</RecipeDef>
