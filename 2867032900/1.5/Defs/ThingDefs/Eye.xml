<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>ElectromechanicalEye</defName>
		<label>Electromechanical eye</label>
		<description>An electronic eye with a mediocre but familiar picture of reality.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>ElectromechanicalEye</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.010</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>ElectromechanicalEye</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisYellowBase">
		<defName>ElectromechanicalEye</defName>
		<label>Electromechanical eye</label>
		<description>An electronic eye with a mediocre but familiar picture of reality.</description>
		<graphicData>
			<texPath>Things/Items/YellowEye</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>0.3</Mass>
		</statBases>
		<costList>
			<Steel>20</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>OrgansReplacement</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>ElectromechanicalEye</defName>
		<label>Install electromechanical eye</label>
		<description>Install electromechanical eye.</description>
		<jobString>Installing electromechanical eye.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ElectromechanicalEye</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ElectromechanicalEye</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Eye</li>
		</appliedOnFixedBodyParts>
		<addsHediff>ElectromechanicalEye</addsHediff>
	</RecipeDef>
