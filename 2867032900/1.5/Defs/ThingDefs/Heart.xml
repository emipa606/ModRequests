<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>ElectromechanicalHeart</defName>
		<label>Electromechanical heart</label>
		<description>Electronic heart substitute with a fixed rhythm.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>ElectromechanicalHeart</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.020</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>ElectromechanicalHeart</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisYellowBase">
		<defName>ElectromechanicalHeart</defName>
		<label>Electromechanical heart</label>
		<description>Electronic heart substitute with a fixed rhythm.</description>
		<graphicData>
			<texPath>Things/Items/YellowHeart</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Steel>30</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>OrgansReplacement</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>ElectromechanicalHeart</defName>
		<label>Install electromechanical heart</label>
		<description>Install electromechanical heart.</description>
		<jobString>Installing electromechanical heart.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ElectromechanicalHeart</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ElectromechanicalHeart</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Heart</li>
		</appliedOnFixedBodyParts>
		<addsHediff>ElectromechanicalHeart</addsHediff>
	</RecipeDef>
