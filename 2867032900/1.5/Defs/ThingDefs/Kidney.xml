<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!---->
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>ElectromechanicalKidney</defName>
		<label>Electromechanical kidney</label>
		<description>An electronic fluid filter that ensures the functions of the kidney in the body.</description>
		<hediffClass>ProsthesesCore.CustomProsthesis</hediffClass>
		<spawnThingOnRemoved>ElectromechanicalKidney</spawnThingOnRemoved>
		<priceImpact>true</priceImpact>
		<countsAsAddedPartOrImplant>true</countsAsAddedPartOrImplant>
		<addedPartProps>
			<solid>true</solid>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<comps>
			<li Class="ProsthesesCore.HediffCompProperties_ExtraProsthesisProps">
				<worksWithoutPower>false</worksWithoutPower>
				<energyConsume>0.005</energyConsume>
				<energyAccumulate>0</energyAccumulate>
				<worksWithEMP>false</worksWithEMP>
				<EMPDefence>false</EMPDefence>
				<partHealthMult>0.85</partHealthMult>
				<disabledStage>
					<label>disabled</label>
					<partEfficiencyOffset>-1</partEfficiencyOffset>
				</disabledStage>
				<parent>ElectromechanicalKidney</parent>
			</li>
		</comps>
	</HediffDef>
	<ThingDef ParentName="ProsthesisYellowBase">
		<defName>ElectromechanicalKidney</defName>
		<label>Electromechanical kidney</label>
		<description>An electronic fluid filter that ensures the functions of the kidney in the body.</description>
		<graphicData>
			<texPath>Things/Items/YellowKidney</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2</Mass>
		</statBases>
		<costList>
			<Steel>20</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<researchPrerequisite>OrgansReplacement</researchPrerequisite>
		</recipeMaker>
	</ThingDef>
	<RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
		<defName>ElectromechanicalKidney</defName>
		<label>Install electromechanical kidney</label>
		<description>Install electromechanical kidney.</description>
		<jobString>Installing electromechanical kidney.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>ElectromechanicalKidney</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>ElectromechanicalKidney</li>
			</thingDefs>
		</fixedIngredientFilter>
		<appliedOnFixedBodyParts>
			<li>Kidney</li>
		</appliedOnFixedBodyParts>
		<addsHediff>ElectromechanicalKidney</addsHediff>
	</RecipeDef>
