<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <!-- allow cooked meals to be overcooked -->
  <Operation Class="PatchOperationAddModExtension">
    <xpath>Defs/ThingDef[@Name="MealCookedIngredientless"]</xpath>
    <value>
      <li Class="IceWorld.FeastOrFamine.DefExtension">
        <canBeOvercooked>true</canBeOvercooked>
      </li>
    </value>
  </Operation>
</Patch>