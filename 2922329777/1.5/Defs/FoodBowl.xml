<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="FurnitureWithQualityBase">
    <defName>AnimalFoodBowl</defName>
    <label>animal food bowl</label>
    <description>A large bowl for serving food. Tamed animals will prefer to eat from bowls that they've been assigned.</description>
    <thingClass>IceWorld.FeastOrFamine.Building_FoodBowl</thingClass>
    <graphicData>
      <texPath>Things/Building/Furniture/FoodBowl</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <damageData>
        <rect>(0.1,0.1,0.9,0.5)</rect>
      </damageData>
      <drawSize>(1.1,1.1)</drawSize>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <statBases>
      <MaxHitPoints>75</MaxHitPoints>
      <WorkToBuild>250</WorkToBuild>
      <Mass>2</Mass>
      <Flammability>1.0</Flammability>
    </statBases>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>20</costStuffCount>
    <comps>
      <li Class="IceWorld.FeastOrFamine.CompProperties_AnimalFoodBowl"/>
    </comps>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <building>
      <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
      <maxItemsInCell>1</maxItemsInCell>
      <storageGroupTag>FoodBowl</storageGroupTag>
      <blueprintClass>Blueprint_Storage</blueprintClass>
      <fixedStorageSettings>
        <filter>
          <disallowNotEverStorable>true</disallowNotEverStorable>
          <disallowWorsePreferability>DesperateOnlyForHumanlikes</disallowWorsePreferability>
          <categories>
            <li>Foods</li>
          </categories>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <priority>Preferred</priority>
        <filter>
          <thingDefs>
            <li>Kibble</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
      <paintable>true</paintable>
    </building>
    <inspectorTabs>
      <li>ITab_Storage</li>
      <li>IceWorld.FeastOrFamine.ITab_FoodBowlAnimals</li>
    </inspectorTabs>
    <surfaceType>Item</surfaceType>
    <canOverlapZones>false</canOverlapZones>
    <rotatable>false</rotatable>
    <uiIconOffset>(0, -0.15)</uiIconOffset>
    <uiIconScale>0.9</uiIconScale>
    <uiOrder>2055</uiOrder>
  </ThingDef>
</Defs>
