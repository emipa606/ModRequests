<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>Overfed</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>overfed</label>
    <labelNoun>an overfed belly</labelNoun>
    <defaultLabelColor>(0.5, 0.9, 0.5)</defaultLabelColor>
    <description>An excess of food in the stomach. Overfeeding is generally less efficient than grazing, but can be advantageous in food-scarce environments. Excessive overfeeding can lead to lethargy, abdominal pain, and vomiting.</description>
    <scenarioCanAdd>true</scenarioCanAdd>
    <isBad>false</isBad>
    <maxSeverity>3</maxSeverity>
    <comps>
      <li Class="IceWorld.FeastOrFamine.CompPropsSeverityPerDay">
        <lossFactor>-2</lossFactor>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li>
        <label>full</label>
        <hungerRateFactor>0.3</hungerRateFactor>
        <capMods>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.5</postFactor>
          </li>
        </capMods>
      </li>
      <li>
        <label>stuffed</label>
        <minSeverity>0.5</minSeverity>
        <hungerRateFactor>0.3</hungerRateFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.9</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.8</postFactor>
          </li>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.3</postFactor>
          </li>
        </capMods>
      </li>
      <li>
        <label>bursting</label>
        <minSeverity>1.0</minSeverity>
        <hungerRateFactor>0.3</hungerRateFactor>
        <vomitMtbDays>0.1</vomitMtbDays>
        <painOffset>0.2</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.8</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.5</postFactor>
          </li>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.1</postFactor>
          </li>
        </capMods>
      </li>
      <li>
        <label>bursting</label>
        <minSeverity>2.0</minSeverity>
        <hungerRateFactor>0.3</hungerRateFactor>
        <vomitMtbDays>0.05</vomitMtbDays>
        <painOffset>0.2</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.8</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.5</postFactor>
          </li>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.1</postFactor>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
  
  <!-- deprecated; keeping around for save game compatibility -->
  <HediffDef>
    <defName>Indigestion</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>indigestion</label>
    <defaultLabelColor>(0.5, 0.9, 0.5)</defaultLabelColor>
    <description>Abdominal discomfort caused by eating too much food. Symptoms range from mild pain to debilitating nausea and vomiting. The patient will feel better after some time.</description>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>2</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-2.5</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <label>mild</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <label>mild</label>
        <minSeverity>0.2</minSeverity>
        <vomitMtbDays>1</vomitMtbDays>
        <painOffset>0.05</painOffset>
        <hungerRateFactor>0.5</hungerRateFactor>
        <capMods>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.5</postFactor>
          </li>
        </capMods>
      </li>
      <li>
        <label>moderate</label>
        <minSeverity>0.7</minSeverity>
        <vomitMtbDays>0.3</vomitMtbDays>
        <painOffset>0.1</painOffset>
        <hungerRateFactor>0.5</hungerRateFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.9</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.8</postFactor>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <postFactor>0.9</postFactor>
          </li>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.3</postFactor>
          </li>
        </capMods>
      </li>
      <li>
        <label>severe</label>
        <minSeverity>1.2</minSeverity>
        <vomitMtbDays>0.1</vomitMtbDays>
        <painOffset>0.2</painOffset>
        <hungerRateFactor>0.5</hungerRateFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.8</postFactor>
          </li>
          <li>
            <capacity>Moving</capacity>
            <postFactor>0.5</postFactor>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <postFactor>0.8</postFactor>
          </li>
          <li>
            <capacity>Eating</capacity>
            <postFactor>0.1</postFactor>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>