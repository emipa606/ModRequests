<?xml version="1.0" encoding="utf-8" ?>
<Patch>

<!-- Heavy Mech Gestation Recipe Patches -->

<Operation Class="PatchOperationAdd">
    <xpath>/Defs</xpath>
  <value>
  <RecipeDef ParentName="HeavyMechanoidRecipe">
    <defName>CryoCentipede</defName>
    <label>gestate Cryo Centipede</label>
    <description>Gestate a Cryo Centipede mechanoid.</description>
    <gestationCycles>12</gestationCycles>
    <researchPrerequisite>HighMechtech</researchPrerequisite>
    <ingredients Inherit="False">
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>400</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>220</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>SubcoreHigh</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <Mech_CryoCentipede>1</Mech_CryoCentipede>
    </products>
    <descriptionHyperlinks>
      <ThingDef>Mech_CryoCentipede</ThingDef>
    </descriptionHyperlinks>
  </RecipeDef>
	  </value>
</Operation>

<Operation Class="PatchOperationAdd">
  <xpath>Defs/ThingDef[defName="LargeMechGestator"]/recipes</xpath>
  <order>Prepend</order>
  <value>
      <li>CryoCentipede</li>
  </value>
</Operation>

<!-- Heavy Mech Ressurection Recipe Patches -->

	<Operation Class="PatchOperationInsert">
		<xpath>Defs/RecipeDef[defName="ResurrectHeavyMech"]/fixedIngredientFilter/thingDefs/li</xpath>
		<value>
			<li>Corpse_Mech_CryoCentipede</li>
		</value>
	</Operation>
	
  <Operation Class="PatchOperationInsert">
	<xpath>Defs/RecipeDef[defName="ResurrectMediumMech"]/fixedIngredientFilter/thingDefs/li</xpath>
	  <value>
		<li>Corpse_Mech_Glacier</li>
	  </value>
  </Operation>

<Operation Class="PatchOperationAdd">
    <xpath>/Defs</xpath>
  <value>
  <RecipeDef ParentName="HeavyMechanoidRecipe">
    <defName>Glacier</defName>
    <label>gestate Glacier</label>
    <description>Gestate a Glacier mechanoid.</description>
    <gestationCycles>2</gestationCycles>
    <researchPrerequisite>StandardMechtech</researchPrerequisite>
    <ingredients Inherit="False">
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>90</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>3</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>SubcoreRegular</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <Mech_Glacier>1</Mech_Glacier>
    </products>
    <descriptionHyperlinks>
      <ThingDef>Mech_Glacier</ThingDef>
    </descriptionHyperlinks>
  </RecipeDef>
	  </value>
</Operation>

<Operation Class="PatchOperationAdd">
  <xpath>Defs/ThingDef[defName="LargeMechGestator"]/recipes</xpath>
  <order>Prepend</order>
  <value>
      <li>Glacier</li>
  </value>
</Operation>

</Patch>