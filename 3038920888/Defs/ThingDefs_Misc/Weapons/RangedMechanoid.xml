<?xml version="1.0" encoding="utf-8" ?>
<Defs>



  <!-- Cryo cannon -->

  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_CryoCannon</defName>
    <label>Cryo cannon shell</label>
    <graphicData>
      <texPath>Things/Projectile/LauncherShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <color>(0,255,255)</color>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
			<damageDef>CryoGas_Liquid</damageDef>
			<damageAmountBase>5</damageAmountBase>
			<stoppingPower>10</stoppingPower>
			<speed>45</speed>
			<explosionRadius>4.5</explosionRadius>
			<postExplosionSpawnThingDef>CryoGasLiquid</postExplosionSpawnThingDef>
			<postExplosionSpawnChance>1.0</postExplosionSpawnChance>
			<preExplosionSpawnThingDef>Filth_PowderSnow_S</preExplosionSpawnThingDef>
			<preExplosionSpawnChance>0.7</preExplosionSpawnChance>
			<arcHeightFactor>0.0</arcHeightFactor>
			<shadowSize>0.0</shadowSize>
			<ai_IsIncendiary>false</ai_IsIncendiary>
			<screenShakeFactor>0.15</screenShakeFactor>
			
			<soundExplosion>Cryo_Shot</soundExplosion>
			<soundExplode>Cryo_Shot</soundExplode>
			<landedEffecter>ExtinguisherPuffSmall</landedEffecter>
    </projectile>
  </ThingDef>

  <ThingDef Abstract="True" ParentName="BaseGun" Name="Gun_CryoCannonBase">
    <label>Cryo cannon</label>
    <description>An cryo shot device, shoots a shell that will burst into a small zone of liquid nitrogen, freezing the area.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/InfernoCannon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>1400</MarketValue>
      <Mass>18</Mass>
      <RangedWeapon_Cooldown>8</RangedWeapon_Cooldown>
    </statBases>
    <techLevel>Spacer</techLevel>
    <generateCommonality>0.5</generateCommonality>
    <tradeability>None</tradeability>
    <weaponClasses>
      <li>RangedHeavy</li>
    </weaponClasses>
    <tools>
      <li>
        <label>barrel</label>
        <capacities>
        <li>Frostbite</li>
        </capacities>
        <power>5.7</power>
        <cooldownTime>2.6</cooldownTime>
      </li>
    </tools>
    <relicChance>0</relicChance>
  </ThingDef>

  <ThingDef ParentName="Gun_CryoCannonBase">
    <defName>Gun_CryoCannon</defName>
    <destroyOnDrop>true</destroyOnDrop>
    <weaponTags>
      <li>MechanoidGunHeavy</li>
      <li>CryoCannonGun</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_CryoCannon</defaultProjectile>
        <forcedMissRadius>5.5</forcedMissRadius>
        <ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
        <warmupTime>2.0</warmupTime>
        <range>50.0</range>
        <burstShotCount>2</burstShotCount>
        <soundCast>Ice_cannon</soundCast>
        <soundCastTail>Ice_cannon</soundCastTail>
        <muzzleFlashScale>14</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>
  
 

</Defs>