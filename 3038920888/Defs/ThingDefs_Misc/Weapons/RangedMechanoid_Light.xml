<?xml version="1.0" encoding="utf-8" ?>
<Defs>


  <ThingDef ParentName="LightMechanoidGunRanged">
    <defName>Gun_MiniCryoblaster</defName>
    <label>mini-cryoblaster</label>
    <description>A small burst-oriented cryo sprayer used by mechanoids.</description>
    <graphicData>
      <texPath>Things/Weapons/MiniCryoBlaster</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
      <Mass>1.0</Mass>
      <AccuracyTouch>0.40</AccuracyTouch>
      <AccuracyShort>0.55</AccuracyShort>
      <AccuracyMedium>0.35</AccuracyMedium>
      <AccuracyLong>0.21</AccuracyLong>
      <RangedWeapon_Cooldown>4.0</RangedWeapon_Cooldown>      
    </statBases>
    <weaponTags>
      <li>MechanoidGunMiniCryoblaster</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
		<defaultProjectile>FrostShot</defaultProjectile>
        <hasStandardCommand>true</hasStandardCommand>
        <warmupTime>0</warmupTime>
        <range>14</range>
        <ticksBetweenBurstShots>7</ticksBetweenBurstShots>
        <burstShotCount>6</burstShotCount>
        <soundCast>Ice_Pew</soundCast>
        <soundCastTail>Ice_Pew</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

<ThingDef ParentName="BaseBullet">
    <defName>FrostShot</defName>
    <label>cryo liquid</label>
    <graphicData>
      <texPath>Things/Projectile/Frostshot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <color>(200,215,215)</color>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
			<damageDef>CryoGas_Liquid</damageDef>
			<damageAmountBase>1</damageAmountBase>
			<stoppingPower>24</stoppingPower>
			<speed>45</speed>
			<explosionRadius>1.2</explosionRadius>
			<postExplosionSpawnThingDef>CryoGasLiquid</postExplosionSpawnThingDef>
			<postExplosionSpawnChance>1.0</postExplosionSpawnChance>
			<preExplosionSpawnThingDef>Filth_PowderSnow_S</preExplosionSpawnThingDef>
			<preExplosionSpawnChance>1.0</preExplosionSpawnChance>
			<arcHeightFactor>0.55</arcHeightFactor>
			<shadowSize>0.5</shadowSize>
			<ai_IsIncendiary>false</ai_IsIncendiary>
			<screenShakeFactor>0</screenShakeFactor>
			<soundExplosion>Ice_Splash</soundExplosion>
			<soundExplode>Ice_Crackle</soundExplode>
			<landedEffecter>ExtinguisherPuffSmall</landedEffecter>
    </projectile>
  </ThingDef>

</Defs>