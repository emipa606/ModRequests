<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <FactionDef ParentName="OutlanderFactionBase">
    <defName>RE_Z1Faction</defName>
    <label>industrious elsen</label>
    <description>A loose collective of Elsen with origins in Zone 1. They are highly industrious, concerning themselves with matters of mining, agriculture, and manufacturing above all else. This particular group holds civility in high regard, and is reluctantly trusting of outsiders.</description>
    <colorSpectrum>
      <li>(0, 1, 0)</li>
      <li>(0.6, 1, 0)</li>
    </colorSpectrum>
    <maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
    <factionIconPath>Map/re_zone1</factionIconPath>
    <configurationListOrderPriority>31</configurationListOrderPriority>
    <requiredMemes>
      <li MayRequire="vanillaexpanded.vmemese">VME_Structure_Corporate</li>
      <li MayRequire="vanillaexpanded.vmemese, vanillaexpanded.vcooke">VME_SweetTeeth</li>
      <li MayRequire="vanillaexpanded.vmemese">VME_HardcoreIndustrialism</li>
      <li MayRequire="ludeon.rimworld.ideology">Rancher</li>
    </requiredMemes>
    <xenotypeSet Inherit="False">
      <xenotypeChances>
        <Elsen>1.0</Elsen>
      </xenotypeChances>
    </xenotypeSet>
  </FactionDef>

  <FactionDef ParentName="OutlanderFactionBase">
    <defName>RE_Z2Faction</defName>
    <label>leisurely elsen</label>
    <description>A loose collective of Elsen with origins in Zone 2. They are highly social, concerning themselves with matters of recreation and comfort above all else. This particular group holds civility in high regard, and is reluctantly trusting of outsiders.</description>
    <colorSpectrum>
      <li>(0.1, 0, 0.7)</li>
      <li>(0.1, 0, 0.9)</li>
    </colorSpectrum>
    <maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
    <factionIconPath>Map/re_zone2</factionIconPath>
    <configurationListOrderPriority>32</configurationListOrderPriority>
    <requiredMemes>
      <li MayRequire="vanillaexpanded.vmemese">VME_Structure_Corporate</li>
      <li MayRequire="vanillaexpanded.vmemese, vanillaexpanded.vcooke">VME_SweetTeeth</li>
      <li MayRequire="vanillaexpanded.vmemese, vanillaexpanded.vbookse">VME_Cultured</li>
    </requiredMemes>
    <xenotypeSet Inherit="False">
      <xenotypeChances>
        <Elsen>1.0</Elsen>
      </xenotypeChances>
    </xenotypeSet>
  </FactionDef>

  <FactionDef ParentName="OutlanderFactionBase">
    <defName>RE_Z3Faction</defName>
    <label>saccharine elsen</label>
    <description>A loose collective of Elsen with origins in Zone 3. They are highly unusual, concerning themselves with matters of sugar and productivity... whatever that means. This particular group holds civility in high regard, and is reluctantly trusting of outsiders.</description>
    <colorSpectrum>
      <li>(1, 0.6, 0)</li>
      <li>(1, 0.3, 0)</li>
    </colorSpectrum>
    <maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
    <factionIconPath>Map/re_zone3</factionIconPath>
    <configurationListOrderPriority>33</configurationListOrderPriority>
    <requiredMemes>
      <li MayRequire="vanillaexpanded.vmemese">VME_Structure_Corporate</li>
      <li MayRequire="vanillaexpanded.vmemese, vanillaexpanded.vcooke">VME_SweetTeeth</li>
      <li MayRequire="vanillaexpanded.vmemese">VME_Gestalt</li>
      <li MayRequire="vanillaexpanded.vmemese">VME_Progressive</li>
    </requiredMemes>
    <xenotypeSet Inherit="False">
      <xenotypeChances>
        <Elsen>1.0</Elsen>
      </xenotypeChances>
    </xenotypeSet>
  </FactionDef>

</Defs>