<Defs>

  <RulePackDef>
    <defName>NamerPersonElsen</defName>
    <rulePack>
      <rulesStrings>
        <li>r_name->[firstName] [lastName]</li>
        <li>r_name->[firstName] '[nickName]' [lastName]</li>

        <li>firstName(p=1)->[SylEl][SylEl][nameEnd]</li>
        <li>firstName(p=3)->[SylEl][nameEnd]</li>

        <li>nickName->[nicknameElsen]</li>

        <li>lastName(p=3)->[lastGenerated]</li>
        <li>lastGenerated->E1-[NumEl][NumEl][NumEl]</li>
        <li>lastGenerated->E2-[NumEl][NumEl][NumEl]</li>
        <li>lastGenerated->E3-[NumEl][NumEl][NumEl]</li>

        <li>nameEnd->och</li>
        <li>nameEnd->ie</li>
        <li>nameEnd->arie</li>
        <li>nameEnd->ary</li>
        <li>nameEnd->elle</li>
        <li>nameEnd->il</li>
        <li>nameEnd->en</li>
        <li>nameEnd->in</li>
        <li>nameEnd->ic</li>
        <li>nameEnd->mel</li>
        <li>nameEnd->ach</li>
        <li>nameEnd->ich</li>
        <li>nameEnd->er</li>
        <li>nameEnd->el</li>
        <li>nameEnd->ig</li>
        <li>nameEnd->ec</li>
        <li>nameEnd->mer</li>
        <li>nameEnd->de</li>
        <li>nameEnd->dre</li>
        <li>nameEnd->cre</li>

      </rulesStrings>
      <rulesFiles>
        <li>SylEl->WordParts/Syllables_Elsen</li>
        <li>NumEl->Misc/Numbers_Singular</li>
        <li>nicknameElsen->Names/Nick_Unisex_Elsen</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>

</Defs>