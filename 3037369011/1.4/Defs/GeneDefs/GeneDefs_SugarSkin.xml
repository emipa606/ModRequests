<?xml version="1.0" encoding="UTF-8"?>
<Defs>

<GeneDef ParentName="GeneHeadboneBase">
	<defName>RimElsen_SugarSkin</defName>
	<label>sugarskin</label>
	<labelShortAdj>sugarskinned</labelShortAdj>
	<description>Carriers of this gene have skin rich in yeast and sucrose compounds. Their fragile crystalline cell structure makes them vulnerable to damage from fire and heat-based weapons.</description>
	<biostatCpx>1</biostatCpx>
	<biostatMet>2</biostatMet>
	<displayCategory>Miscellaneous</displayCategory>
	<displayOrderInCategory>401</displayOrderInCategory>
	<iconPath>Genes/UI/Sugarskin</iconPath>
	<iconColor>(0.75, 0.75, 0.75)</iconColor>
    <forcedHeadTypes>
      <li>Male_AverageNormal</li>
      <li>Male_AverageWide</li>
      <li>Male_AveragePointy</li>
      <li>Female_AverageNormal</li>
      <li>Female_AverageWide</li>
    </forcedHeadTypes>
	<exclusionTags>
		<li>BeardStyle</li>
		<li>HairStyle</li>
	</exclusionTags>
	<beardTagFilter>
     		<whitelist>true</whitelist>
      		<tags>
        			<li>NoBeard</li>
      		</tags>
   	</beardTagFilter>
	<hairTagFilter>
		<whitelist>true</whitelist>
		<tags>
			<li>Bald</li>
		</tags>
	</hairTagFilter>
	<statOffsets>
		<ArmorRating_Heat>-0.15</ArmorRating_Heat>
	</statOffsets>
	<damageFactors>
		<Flame>1.2</Flame>
	</damageFactors>
	<graphicData>
     		<useSkinShader>true</useSkinShader>
		<graphicPath>Genes/Headbone/Squared</graphicPath>
      		<layer>PostSkin</layer>
		<colorType>Skin</colorType>
		<tattoosVisible>true</tattoosVisible>
	</graphicData>
</GeneDef>

</Defs>