  <!--   backpack   -->
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>chw_ManchuBackpack</defName>
    <label>Manchu Army backpack</label>
    <description>.</description>
    <graphicData>
      <texPath>Things/Apparel/ManchuBackpack/ManchuBackpack</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <costList>
      <Cloth>40</Cloth>
    </costList>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
    </recipeMaker>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>2500</WorkToMake>
      <Mass>1</Mass>
      <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.07</ArmorRating_Blunt>
      <EquipDelay>1.5</EquipDelay>
    </statBases>
    <thingCategories>
      <li>ApparelMisc</li>
    </thingCategories>
    <apparel>
      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <tags>
        <li>IndustrialAdvanced</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <wornGraphicPath>Things/Apparel/ManchuBackpack/ManchuBackpack</wornGraphicPath>
      <wornGraphicData>
      <renderUtilityAsPack>true</renderUtilityAsPack>
        <east>
          <offset>(0,-0.05)</offset>
          <thin><offset>(0.2,0)</offset></thin>
          <hulk><offset>(0,0)</offset></hulk>
          <fat><offset>(0,0)</offset></fat>
          <male><offset>(0.125,0)</offset></male>
          <female><offset>(0.125,0)</offset></female>	
        </east>
        <west>
          <offset>(0,-0.05)</offset>
          <thin><offset>(-0.2,0)</offset></thin>
          <hulk><offset>(0,0)</offset></hulk>
          <fat><offset>(0,0)</offset></fat>
          <male><offset>(-0.125,0)</offset></male>
          <female><offset>(-0.125,0)</offset></female>		  
        </west>
        <north>
          <offset>(0,-0.1)</offset> 
          <thin><offset>(0,0)</offset></thin>
          <hulk><offset>(0,-0.05)</offset></hulk>
          <fat><offset>(0,-0.05)</offset></fat>
        </north>		
        <male>  <scale>(1,1)</scale></male>
        <female><scale>(1,1)</scale></female>
        <thin>  <scale>(1,1)</scale></thin>
        <hulk>  <scale>(1,1)</scale></hulk>
        <fat>   <scale>(1,1)</scale></fat>
      </wornGraphicData>
    </apparel>
    <tradeTags>
      <li>Clothing</li>
    </tradeTags>
  </ThingDef>


